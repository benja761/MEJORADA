--==================================================
local function applyVisual(target, root, titleText, infoText, fillColor, textColor)
	local record = ensureVisual(target)
	record.Highlight.Adornee = target
	record.Highlight.FillColor = fillColor
	record.Highlight.OutlineColor = fillColor
	record.Billboard.Adornee = root
	record.Title.Text = titleText
	record.Title.TextColor3 = textColor
	record.Info.Text = infoText
	record.Info.TextColor3 = textColor
end

local function updateNPCs(alive)
	PerfStats.VisibleNPCs = 0
	if not Settings.NPCEnabled then
		return
	end
	local targets = collectByTagOrFolder(Settings.NPCUseTags, Settings.NPCTag, Settings.NPCFolders)
	for i = 1, math.min(#targets, Settings.MaxTrackedPerGroup) do
		local target = targets[i]
		if isAliveInstance(target) then
			local root = getRoot(target)
			if root then
				local distance = getDistanceFromLocal(root.Position)
				if distance <= Settings.NPCMaxDistance then
					local hum = getHumanoid(target)
					local titleText = Settings.NPCNames and safeName(target) or "NPC"
					local info = {}
					if Settings.NPCDistance then table.insert(info, string.format("%dm", math.floor(distance))) end
					if Settings.NPCHealth and hum then
						table.insert(info, string.format("HP %d/%d", math.floor(hum.Health), math.floor(hum.MaxHealth)))
					end
					if Settings.NPCState then
						local state = getCommonState(target)
						if state then table.insert(info, state) end
					end
					if Settings.NPCTarget then
						local targetName = getCommonTarget(target)
						if targetName then table.insert(info, "T:" .. targetName) end
					end
					applyVisual(target, root, titleText, table.concat(info, " | "), Settings.NPCFillColor, Settings.NPCTextColor)
					alive[target] = true
					PerfStats.VisibleNPCs = PerfStats.VisibleNPCs + 1
				end
			end
		end
	end
end

local function updateObjects(alive)
