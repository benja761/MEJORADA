local function createSlider(parent, title, description, min, max, defaultValue, callback)
    local holder = createControlHolder(parent, 70)
    local titleLabel = create("TextLabel", {
        Parent = holder,
        BackgroundTransparency = 1,
        Position = UDim2.fromOffset(12, 8),
        Size = UDim2.new(1, -80, 0, 16),
