local function removeESPRecord(target)
    local rec = App.ESP[target]
    if not rec then return end
    pcall(function() rec.LineGlow:Remove() end)
    pcall(function() rec.Line:Remove() end)
    pcall(function() rec.BoxGlow:Remove() end)
    pcall(function() rec.Box:Remove() end)
    pcall(function() rec.HealthGlowLine:Remove() end)
    pcall(function() rec.HealthBackLine:Remove() end)
    pcall(function() rec.HealthLine:Remove() end)
    pcall(function() rec.HeadGlow:Remove() end)
    pcall(function() rec.HeadCircle:Remove() end)
    pcall(function() rec.NameShadow:Remove() end)
    pcall(function() rec.NameText:Remove() end)
    for _, l in ipairs(rec.CornerGlow) do pcall(function() l:Remove() end) end
    for _, l in ipairs(rec.Corners) do pcall(function() l:Remove() end) end
    for _, c in ipairs(rec.CornerRoundGlow) do pcall(function() c:Remove() end) end
    for _, c in ipairs(rec.CornerRound) do pcall(function() c:Remove() end) end
    for _, c in ipairs(rec.HealthBackCaps) do pcall(function() c:Remove() end) end
    for _, c in ipairs(rec.HealthFillCaps) do pcall(function() c:Remove() end) end
    for _, c in ipairs(rec.HealthGlowCaps) do pcall(function() c:Remove() end) end
    for _, l in ipairs(rec.SkeletonGlow) do pcall(function() l:Remove() end) end
    for _, l in ipairs(rec.Skeleton) do pcall(function() l:Remove() end) end
    if rec.Folder then pcall(function() rec.Folder:Destroy() end) end
    App.ESP[target] = nil
end

