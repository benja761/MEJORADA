local function buildFovCircle()
	App.FovCircle = create("Frame", {
		BackgroundTransparency = 1,
		AnchorPoint = Vector2.new(0.5, 0.5),
		Position = UDim2.new(0.5, 0, 0.5, 0),
		Size = UDim2.new(0, State.AimFov * 2, 0, State.AimFov * 2),
		Visible = State.AimShowFOV,
		Parent = App.Gui
	})
	local corner = Instance.new("UICorner")
	corner.CornerRadius = UDim.new(1, 0)
	corner.Parent = App.FovCircle

	local stroke = Instance.new("UIStroke")
	stroke.Thickness = 1.5
	stroke.Color = App.Theme.Accent
	stroke.Parent = App.FovCircle
end

local function refreshFovState()
	if not App.FovCircle then return end
	local size = math.max(40, tonumber(State.AimFov) or 140) * 2
	App.FovCircle.Size = UDim2.new(0, size, 0, size)
	App.FovCircle.Position = UDim2.new(0.5, 0, 0.5, 0)
	App.FovCircle.Visible = State.MenuVisible and State.AimShowFOV or false
end

local function refreshMenuState()
	if not App.Root or not App.Gui then
		return
	end

	App.Gui.Enabled = true
	App.Root.Visible = State.MenuVisible

	if App.LoginOverlay then
		App.LoginOverlay.Visible = State.MenuVisible
	end

	if App.PopupLayer then
		App.PopupLayer.Visible = State.MenuVisible
	end

	if App.Sidebar and App.Content then
		App.Sidebar.Visible = State.MenuVisible and (not State.MenuMinimized)
		App.Content.Visible = State.MenuVisible and (not State.MenuMinimized)
	end

	if State.MenuMinimized then
		App.Root.Size = UDim2.new(0, 1000, 0, 74)
	else
		App.Root.Size = UDim2.new(0, 1000, 0, 640)
	end

	if App.HotkeyLabel then
		App.HotkeyLabel.Text = "Toggle: " .. tostring(State.MenuKey.Name)
	end

	if State.Blur then
		setBlur(State.MenuVisible)
	end

	refreshFovState()
end

local function updateSelfMarker()
	if not State.ShowSelfMarker then
		cleanupRecord("self_marker")
		return
	end

	local char = LocalPlayer.Character
	local root = getRoot(char)
	if char and root then
		updateRecord("self_marker", char, root, LocalPlayer.DisplayName, "Self", getColorByName("Purple"))
	else
		cleanupRecord("self_marker")
	end
end

local function hookEvents()
	App.SearchBox:GetPropertyChangedSignal("Text"):Connect(function()
		State.Search = App.SearchBox.Text or ""
		refreshSearch()
	end)

	local dragging = false
	local dragInput = nil
	local dragStart = nil
	local startPos = nil

	local function beginDrag(input)
		if input.UserInputType ~= Enum.UserInputType.MouseButton1 then
			return
		end
		dragging = true
		dragInput = input
		dragStart = input.Position
		startPos = App.Root.Position
	end

	local function updateDrag(input)
		if not dragging or input ~= dragInput or not dragStart or not startPos then
			return
		end

		local delta = input.Position - dragStart
		App.Root.Position = UDim2.new(
			startPos.X.Scale,
			startPos.X.Offset + delta.X,
			startPos.Y.Scale,
			startPos.Y.Offset + delta.Y
		)
	end

	App.DragHandle.InputBegan:Connect(beginDrag)
	App.Header.InputBegan:Connect(beginDrag)

	UserInputService.InputChanged:Connect(function(input)
		if input == dragInput then
			updateDrag(input)
		end
	end)

	UserInputService.InputEnded:Connect(function(input)
		if input == dragInput or input.UserInputType == Enum.UserInputType.MouseButton1 then
			dragging = false
			dragInput = nil
		end
	end)

	App.MinButton.MouseButton1Click:Connect(function()
		State.MenuMinimized = not State.MenuMinimized
		refreshMenuState()
	end)

	App.HideButton.MouseButton1Click:Connect(function()
		State.MenuVisible = not State.MenuVisible
		refreshMenuState()
	end)

	App.CloseButton.MouseButton1Click:Connect(function()
		cleanupAllRecords()
		if App.BlurObject then
			App.BlurObject:Destroy()
			App.BlurObject = nil
		end
		if App.Gui then
			App.Gui:Destroy()
		end
	end)

	UserInputService.InputBegan:Connect(function(input, gp)
		if gp then
			return
		end

		if input.KeyCode == State.MenuKey then
			State.MenuVisible = not State.MenuVisible
			refreshMenuState()
		end
	end)

	LocalPlayer.CharacterAdded:Connect(function(char)
		task.wait(0.35)
		local hum = getHumanoid(char)
		if hum then
			hum.WalkSpeed = State.LocalWalkSpeed
			hum.JumpPower = State.LocalJumpPower
		end
	end)

	refreshMenuState()
	refreshFovState()
end

local function loop()
	local accum = 0
	RunService.RenderStepped:Connect(function(dt)
		accum = accum + dt
		refreshFovState()

		if accum >= State.RefreshRate then
			accum = 0
			updateVisualRecords()
			updateSelfMarker()
		end
	end)
end

