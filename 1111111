		Visible = false
	})
	page.Parent = App.PageHolder
	local layout = create("UIListLayout", {
		Padding = UDim.new(0, 10),
		SortOrder = Enum.SortOrder.LayoutOrder
	})
	layout.Parent = page
	addPadding(page, 2, 4, 2, 2)
	App.Pages[name] = {Frame = page, Description = description or ""}
	return page
end

local function switchTab(name)
	local pageName, page
	App.ActiveTab = name
	for pageName, page in pairs(App.Pages) do
		page.Frame.Visible = (pageName == name)
	end
	for pageName, page in pairs(App.TabButtons) do
		if page and page.Parent then
			if pageName == name then
				page.BackgroundColor3 = App.Theme.Section
			else
				page.BackgroundColor3 = App.Theme.Panel
			end
		end
	end
	if App.PageTitle then
		App.PageTitle.Text = name
	end
	if App.PageDesc and App.Pages[name] then
		App.PageDesc.Text = App.Pages[name].Description
	end
	refreshSearch()
end

