				local max = sliderData.Max or 100
				local decimals = sliderData.Decimals or 0
				local value = sliderData.Default or min
				local suffix = sliderData.Suffix or ""
				Library.Flags[flag] = value

				local holder, entry = createItemShell((sliderData.Name or "Slider") .. " " .. (sliderData.Description or ""), 72)
				local nameLabel = create("TextLabel", {
					BackgroundTransparency = 1,
					Position = UDim2.new(0, 12, 0, 8),
