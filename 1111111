local function create(className, props)
	local instance = Instance.new(className)
	if props then
		for key, value in pairs(props) do
			instance[key] = value
		end
	end
	return instance
end

local function round(n)
	return math.floor(n + 0.5)
end

local function registerTheme(instance, propertyName, role)
	App.ThemeObjects[role] = App.ThemeObjects[role] or {}
	table.insert(App.ThemeObjects[role], {Instance = instance, Property = propertyName})
	instance[propertyName] = App.Theme[role]
end

local function addCorner(instance, radius)
	local c = Instance.new("UICorner")
	c.CornerRadius = UDim.new(0, radius or 8)
	c.Parent = instance
	return c
end

local function addStroke(instance, role, thickness)
	local s = Instance.new("UIStroke")
	s.Thickness = thickness or 1
	s.ApplyStrokeMode = Enum.ApplyStrokeMode.Border
	s.Parent = instance
	registerTheme(s, "Color", role or "Outline")
	return s
end

local function addPadding(instance, left, right, top, bottom)
	local p = Instance.new("UIPadding")
	p.PaddingLeft = UDim.new(0, left or 0)
	p.PaddingRight = UDim.new(0, right or left or 0)
	p.PaddingTop = UDim.new(0, top or left or 0)
	p.PaddingBottom = UDim.new(0, bottom or top or left or 0)
	p.Parent = instance
	return p
end

local function tween(object, info, props)
	local tw = TweenService:Create(object, info, props)
	tw:Play()
	return tw
end

local function getColorByName(name)
	for i = 1, #ColorMenus do
		if ColorMenus[i][1] == name then
			return ColorMenus[i][2]
		end
	end
	return App.Theme.Accent
end

local function makeGlow(parent, role)
	local holder = create("Frame", {
		Name = "GlowHolder",
		BackgroundTransparency = 1,
		BorderSizePixel = 0,
		Size = UDim2.new(1, 18, 1, 18),
		Position = UDim2.new(0, -9, 0, -9),
		ZIndex = math.max((parent.ZIndex or 1) - 1, 1)
	})
	holder.Parent = parent
	for i = 1, 3 do
		local ring = create("Frame", {
			BackgroundTransparency = 0.92 + (i * 0.02),
			BorderSizePixel = 0,
			Size = UDim2.new(1, i * 8, 1, i * 8),
			Position = UDim2.new(0, -(i * 4), 0, -(i * 4)),
			ZIndex = holder.ZIndex
		})
		ring.Parent = holder
		addCorner(ring, 12 + (i * 4))
		registerTheme(ring, "BackgroundColor3", role or "Accent")
	end
	holder.Visible = State.Glow
	table.insert(App.GlowHolders, holder)
	return holder
end

local function applyTheme(name)
	local preset = ThemePresets[name] or ThemePresets.PureBlack
	App.Theme = preset
	State.ThemeName = name
	for roleName, items in pairs(App.ThemeObjects) do
		if preset[roleName] then
			for i = 1, #items do
				local item = items[i]
				if item.Instance and item.Instance.Parent then
					pcall(function()
						item.Instance[item.Property] = preset[roleName]
					end)
				end
			end
		end
	end
	if App.FovCircle and App.FovCircle:FindFirstChildOfClass("UIStroke") then
		App.FovCircle:FindFirstChildOfClass("UIStroke").Color = preset.Accent
	end
end

local function setGlowVisible(state)
	State.Glow = state and true or false
	for i = 1, #App.GlowHolders do
		local glow = App.GlowHolders[i]
		if glow and glow.Parent then
			glow.Visible = State.Glow
		end
	end
end

local function setBlur(on)
	State.Blur = on and true or false
	if on then
		if not App.BlurObject then
			App.BlurObject = Instance.new("BlurEffect")
			App.BlurObject.Name = "TonyMontanaBlurFixed"
			App.BlurObject.Size = 0
			App.BlurObject.Parent = Lighting
		end
		App.BlurObject.Enabled = true
		tween(App.BlurObject, TweenInfo.new(0.18, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {Size = 8})
	else
		if App.BlurObject then
			tween(App.BlurObject, TweenInfo.new(0.18, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {Size = 0})
			task.delay(0.2, function()
				if App.BlurObject then
					App.BlurObject.Enabled = false
				end
			end)
		end
	end
end

local function getRoot(model)
	if not model then
		return nil
	end
	if model:IsA("BasePart") then
		return model
	end
	if model:IsA("Model") then
		return model:FindFirstChild("HumanoidRootPart")
			or model.PrimaryPart
			or model:FindFirstChild("Head")
			or model:FindFirstChildWhichIsA("BasePart")
	end
	return nil
end

local function getHumanoid(model)
	if model and model:IsA("Model") then
		return model:FindFirstChildOfClass("Humanoid")
	end
	return nil
end

local function getLocalRoot()
	local char = LocalPlayer.Character
	if not char then
		return nil
	end
	return char:FindFirstChild("HumanoidRootPart")
end

local function getDistanceFromLocal(position)
	local root = getLocalRoot()
	if not root then
		return math.huge
	end
	return (root.Position - position).Magnitude
end

