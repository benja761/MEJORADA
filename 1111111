	if not rec then return end
	pcall(function() if rec.Highlight then rec.Highlight:Destroy() end end)
	pcall(function() if rec.Billboard then rec.Billboard:Destroy() end end)
	Tracked[target] = nil
end

local function cleanupAllVisuals()
