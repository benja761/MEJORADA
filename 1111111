    d.Parent = h
    registerTheme(d, "TextColor3", "Sub")
    local value = create("TextLabel", {BackgroundTransparency=1, AnchorPoint=Vector2.new(1,0), Position=UDim2.new(1,-12,0,8), Size=UDim2.new(0,56,0,16), Text=tostring(default), Font=Enum.Font.GothamBold, TextSize=12, TextXAlignment=Enum.TextXAlignment.Right})
    value.Parent = h
    registerTheme(value, "TextColor3", "Accent")

    local bar = create("Frame", {BorderSizePixel=0, Position=UDim2.new(0,12,0,46), Size=UDim2.new(1,-24,0,10)})
    bar.Parent = h
    registerTheme(bar, "BackgroundColor3", "Main")
    addCorner(bar, 99)
    local fill = create("Frame", {BackgroundColor3=App.Theme.Accent, BorderSizePixel=0, Size=UDim2.new(0,0,1,0)})
    fill.Parent = bar
    addCorner(fill, 99)

    local dragging = false
    local state = default
    local function fmt(v)
        if math.floor(v) == v then return tostring(v) end
        return string.format("%.1f", v)
    end
    local function set(v)
        v = math.clamp(round(v, step or 1), min, max)
        state = v
        local pct = (v - min) / math.max(max - min, 1)
        fill.Size = UDim2.new(pct,0,1,0)
        value.Text = fmt(v)
        if cb then cb(v) end
    end
    local function update(px)
        local pct = math.clamp((px - bar.AbsolutePosition.X) / math.max(bar.AbsoluteSize.X, 1), 0, 1)
        set(min + (max - min) * pct)
    end
    bar.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then dragging = true; update(input.Position.X) end
    end)
    table.insert(App.Connections, UserInputService.InputChanged:Connect(function(input)
        if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then update(input.Position.X) end
    end))
    table.insert(App.Connections, UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then dragging = false end
    end))
    set(default)
    return {Set=set, Get=function() return state end}
end

