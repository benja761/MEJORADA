                set(v)
                popup.Visible = false
            end)
        end
        popup.Size = UDim2.new(0, popupWidth, 0, math.min(#currentValues, 6) * 24 + 12)
    end

    b.MouseButton1Click:Connect(function()
        hideAllPopups()
        local p, s = b.AbsolutePosition, b.AbsoluteSize
        popup.Position = UDim2.new(0, p.X + s.X - popupWidth, 0, p.Y + s.Y + 4)
        popup.Visible = not popup.Visible
    end)

    rebuildRows()
    set(default)
    return {
        Set=set,
        Get=function() return state end,
        SetOptions=function(newValues, preferred)
            currentValues = newValues or {}
            rebuildRows()
            if preferred ~= nil then
                set(preferred)
            elseif #currentValues > 0 then
                local found = false
                for _, item in ipairs(currentValues) do
                    if item == state then found = true break end
                end
                if not found then set(currentValues[1]) end
            end
        end
    }
end

