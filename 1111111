	createSlider(player1, "JumpPower", 0, 150, function() return State.JumpPower end, function(v) State.JumpPower = v end)
	createButton(player1, "Apply Movement Now", function()
		local ch = getCharacter()
		local hum = ch and ch:FindFirstChildOfClass("Humanoid")
		if hum then
			hum.WalkSpeed = State.WalkSpeed
			hum.JumpPower = State.JumpPower
			notify("Player", "Movement values applied.", Theme.Good)
		end
	end)

	local perf1 = makeSection(perfPage, "Performance", "Keep the panel responsive and compatible")
	createToggle(perf1, "Auto Refresh", function() return State.AutoRefresh end, function(v) State.AutoRefresh = v end)
	createSlider(perf1, "Refresh Rate x100", 3, 100, function() return math.floor(State.RefreshRate * 100) end, function(v) State.RefreshRate = v / 100 end)
	createSlider(perf1, "Max Tracked", 25, 500, function() return State.MaxTracked end, function(v) State.MaxTracked = v end)
	createSlider(perf1, "Invisible Threshold x100", 0, 100, function() return math.floor(State.InvisibleThreshold * 100) end, function(v) State.InvisibleThreshold = v / 100 end)
	createButton(perf1, "Print Live Counters", function()
		print("VisibleNPCs", Stats.VisibleNPCs)
		print("VisibleObjects", Stats.VisibleObjects)
		print("VisibleSpawns", Stats.VisibleSpawns)
		print("VisibleTriggers", Stats.VisibleTriggers)
		print("VisiblePaths", Stats.VisiblePaths)
		print("VisibleWorld", Stats.VisibleWorld)
	end)

	local settings1 = makeSection(settingsPage, "Theme / Menu", "Appearance and menu behavior")
	createDropdown(settings1, "Theme", {"Red", "Dark", "PureBlack"}, function() return State.ThemeName end, function(v) State.ThemeName = v themeRefresh() switchTab(State.CurrentTab) end)
	createTextbox(settings1, "Menu Toggle Key", function() return State.ToggleKey.Name end, function(v) end, "RightShift")
	createButton(settings1, "Show Default Access Code", function() notify("Login", "Default local code: " .. State.AccessCode, Theme.Warn) end)
	createButton(settings1, "Destroy Panel", function()
		cleanupAllVisuals()
		disconnectAll()
		pcall(function() if UI.Blur then UI.Blur:Destroy() end end)
		pcall(function() if UI.Gui then UI.Gui:Destroy() end end)
	end)

	connect(search:GetPropertyChangedSignal("Text"), function()
		State.Search = search.Text
		applySearch()
	end)

	connect(closeBtn.MouseButton1Click, function()
		cleanupAllVisuals()
		disconnectAll()
		pcall(function() if UI.Blur then UI.Blur:Destroy() end end)
		pcall(function() if UI.Gui then UI.Gui:Destroy() end end)
	end)

	connect(minBtn.MouseButton1Click, function()
		State.Minimized = not State.Minimized
		left.Visible = not State.Minimized
		content.Visible = not State.Minimized
		main.Size = State.Minimized and UDim2.new(0, 980, 0, 48) or UDim2.new(0, 980, 0, 620)
	end)

	connect(loginBtn.MouseButton1Click, function()
		if tostring(codeBox.Text) == State.AccessCode then
			State.LoggedIn = true
			login.Visible = false
			main.Visible = true
			notify("Loaded", "Premium compat panel opened.", Theme.Good)
		else
			notify("Login", "Wrong code.", Theme.Warn)
		end
	end)

	local dragStart, startPos, dragInput
	connect(header.InputBegan, function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 then
			State.Dragging = true
			dragStart = input.Position
			startPos = main.Position
			connect(input.Changed, function()
				if input.UserInputState == Enum.UserInputState.End then
					State.Dragging = false
				end
			end)
		end
	end)
	connect(header.InputChanged, function(input)
		if input.UserInputType == Enum.UserInputType.MouseMovement then
			dragInput = input
		end
	end)
	connect(UserInputService.InputChanged, function(input)
		if State.Dragging and input == dragInput then
			local delta = input.Position - dragStart
			main.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
		end
	end)
	connect(UserInputService.InputBegan, function(input, gp)
		if gp then return end
		if input.KeyCode == State.ToggleKey then
			State.MenuOpen = not State.MenuOpen
			main.Visible = State.MenuOpen and State.LoggedIn
			login.Visible = State.MenuOpen and (not State.LoggedIn)
		end
		if codeBox:IsFocused() then return end
		if input.KeyCode ~= Enum.KeyCode.Unknown then
			if UI.KeyPrompt and UI.KeyPrompt.Visible then
				State.ToggleKey = input.KeyCode
				UI.KeyLabel.Text = State.ToggleKey.Name
				UI.KeyPrompt.Visible = false
			end
		end
	end)

	local keyBtn = create("TextButton", {BackgroundColor3 = Theme.Control, BorderSizePixel = 0, Position = UDim2.new(0,10,0,44), Size = UDim2.new(1,-20,0,34), Text = "Bind Toggle Key", TextColor3 = Theme.Text, Font = Enum.Font.GothamBold, TextSize = 13, AutoButtonColor = false})
	keyBtn.Parent = settings1.Parent
	addCorner(keyBtn, 8)
	addStroke(keyBtn, Theme.Outline, 1)
	registerSearch(keyBtn, function() return "Bind Toggle Key" end)
	local keyLabel = create("TextLabel", {BackgroundTransparency = 1, AnchorPoint = Vector2.new(1,0.5), Position = UDim2.new(1,-10,0.5,0), Size = UDim2.new(0,80,1,0), Text = State.ToggleKey.Name, TextColor3 = Theme.Text, Font = Enum.Font.Gotham, TextSize = 12, TextXAlignment = Enum.TextXAlignment.Right})
	keyLabel.Parent = keyBtn
	UI.KeyLabel = keyLabel
	local keyPrompt = create("TextLabel", {BackgroundTransparency = 1, Position = UDim2.new(0,0,1,-24), Size = UDim2.new(1,0,0,20), Text = "Press a key...", Visible = false, TextColor3 = Theme.Warn, Font = Enum.Font.GothamBold, TextSize = 11})
	keyPrompt.Parent = settings1.Parent
	UI.KeyPrompt = keyPrompt
	connect(keyBtn.MouseButton1Click, function() keyPrompt.Visible = true end)

	switchTab("Visual")
	themeRefresh()
end

buildUI()

local function updatePlayerStats()
	if not State.MovementOverride then return end
	local ch = getCharacter()
	local hum = ch and ch:FindFirstChildOfClass("Humanoid")
	if hum then
		hum.WalkSpeed = State.WalkSpeed
		hum.JumpPower = State.JumpPower
	end
end

local SelfMarker
local SelfBillboard
local function updateSelfVisuals()
	local root = getLocalRoot()
	if State.RootMarker and root then
		if not SelfMarker then
			SelfMarker = Instance.new("Highlight")
			SelfMarker.FillTransparency = 0.8
			SelfMarker.OutlineTransparency = 0
			SelfMarker.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
			SelfMarker.Parent = root
		end
		SelfMarker.Adornee = root
		SelfMarker.FillColor = Theme.Accent
		SelfMarker.OutlineColor = Theme.Accent
	else
		if SelfMarker then SelfMarker:Destroy() SelfMarker = nil end
	end
	if State.VelocityLabel and root then
		if not SelfBillboard then
			SelfBillboard = Instance.new("BillboardGui")
			SelfBillboard.Size = UDim2.new(0, 120, 0, 24)
			SelfBillboard.AlwaysOnTop = true
			SelfBillboard.StudsOffset = Vector3.new(0, 2.5, 0)
			SelfBillboard.Parent = root
			local lbl = create("TextLabel", {Name = "Label", BackgroundTransparency = 1, Size = UDim2.new(1,0,1,0), TextScaled = true, TextColor3 = Theme.Text, TextStrokeTransparency = 0, Font = Enum.Font.GothamBold})
			lbl.Parent = SelfBillboard
		end
		SelfBillboard.Adornee = root
		local speed = root.AssemblyLinearVelocity.Magnitude
		SelfBillboard.Label.Text = "VEL " .. tostring(round(speed))
	else
		if SelfBillboard then SelfBillboard:Destroy() SelfBillboard = nil end
	end
end

spawn(function()
	while UI.Gui and UI.Gui.Parent do
		task.wait(State.RefreshRate)
		if State.AutoRefresh then
			refreshVisuals()
		end
		updatePlayerStats()
		updateSelfVisuals()
	end
end)
