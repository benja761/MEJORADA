    for _, c in ipairs(rec.CornerRound) do c.Visible = false end
    for _, c in ipairs(rec.HealthBackCaps) do c.Visible = false end
    for _, c in ipairs(rec.HealthFillCaps) do c.Visible = false end
    for _, c in ipairs(rec.HealthGlowCaps) do c.Visible = false end
    for _, l in ipairs(rec.SkeletonGlow) do l.Visible = false end
    for _, l in ipairs(rec.Skeleton) do l.Visible = false end
end

local function collectTargets()
    local out = {}
    if State.ESPPlayers then
        for _, plr in ipairs(Players:GetPlayers()) do
            if plr ~= LocalPlayer and plr.Character and isAliveModel(plr.Character) then
                table.insert(out, plr.Character)
            end
        end
    end
    if State.ESPNPCs then
        local seen = {}
        for _, tag in ipairs({"NPC","Enemy","Mob","Bot","DebugNPC"}) do
            for _, m in ipairs(CollectionService:GetTagged(tag)) do
                if m:IsA("Model") and isAliveModel(m) then
                    seen[m] = true
                end
            end
        end
        for _, folderName in ipairs({"NPCs","Enemies","Mobs","Bots"}) do
            local folder = Workspace:FindFirstChild(folderName)
            if folder then
                for _, child in ipairs(folder:GetChildren()) do
                    if child:IsA("Model") and isAliveModel(child) then
                        seen[child] = true
                    end
                end
            end
        end
        for model in pairs(seen) do table.insert(out, model) end
    end
    return out
end



local function getPartByNames(model, names)
    for _, name in ipairs(names) do
        local part = model:FindFirstChild(name)
        if part and part:IsA("BasePart") then
            return part
        end
    end
    return nil
end

local function partToScreen(part)
    if not part then return nil end
    local pos, onScreen = Camera:WorldToViewportPoint(part.Position)
    if onScreen and pos.Z > 0 then
        return Vector2.new(pos.X, pos.Y), pos.Z
    end
    return nil
end

local function passesWallCheck(model, part)
    if not State.WallCheck then return true end
    if not model or not part then return false end
    local origin = Camera.CFrame.Position
    local direction = part.Position - origin
    local params = RaycastParams.new()
    params.FilterType = Enum.RaycastFilterType.Blacklist
    params.FilterDescendantsInstances = {getCharacter(), App.PreviewClone}
    params.IgnoreWater = true
    local result = Workspace:Raycast(origin, direction, params)
    if not result then return true end
    return result.Instance and result.Instance:IsDescendantOf(model)
end

local function getPriorityScore(model)
    local root = getRoot(model)
    local part = getTargetPart(model) or root
    if not root or not part then return math.huge end
    local dist = distanceTo(root.Position)
    local screenPos, onScreen = Camera:WorldToViewportPoint(part.Position)
    local crosshair = math.huge
    if onScreen and screenPos.Z > 0 then
        crosshair = (Vector2.new(screenPos.X, screenPos.Y) - Vector2.new(Camera.ViewportSize.X * 0.5, Camera.ViewportSize.Y * 0.5)).Magnitude
    end
    if State.RenderPriority == "Distance" then
        return dist
    elseif State.RenderPriority == "Health" then
        local hum = getHumanoid(model)
        return hum and hum.Health or math.huge
    end
    return crosshair
end

local function refreshTargetCache()
    App.TargetCache = {}
    if not (State.ESPEnabled or State.CombatEnabled) then return end
    local pool = {}
    for _, model in ipairs(collectTargets()) do
        local root = getRoot(model)
        local hum = getHumanoid(model)
        if root and hum and hum.Health > 0 then
            local dist = distanceTo(root.Position)
            if dist <= State.ESPDistance + 50 then
                table.insert(pool, {Model = model, Score = getPriorityScore(model), Distance = dist})
            end
        end
    end
    table.sort(pool, function(a, b) return a.Score < b.Score end)
    for i = 1, math.min(#pool, math.max(1, State.MaxRenderedTargets)) do
        App.TargetCache[i] = pool[i].Model
    end
end

local function drawSkeleton(rec, model, color, boxH, enabled)
    for _, l in ipairs(rec.SkeletonGlow) do l.Visible = false end
    for _, l in ipairs(rec.Skeleton) do l.Visible = false end
    rec.HeadGlow.Visible = false
    rec.HeadCircle.Visible = false
    if not enabled then return end

    local head = getPartByNames(model, {"Head"})
    local upper = getPartByNames(model, {"UpperTorso", "Torso"})
    local lower = getPartByNames(model, {"LowerTorso", "HumanoidRootPart", "Torso"})
    local lua = getPartByNames(model, {"LeftUpperArm", "Left Arm"})
    local lla = getPartByNames(model, {"LeftLowerArm"})
    local lha = getPartByNames(model, {"LeftHand"})
    local rua = getPartByNames(model, {"RightUpperArm", "Right Arm"})
    local rla = getPartByNames(model, {"RightLowerArm"})
    local rha = getPartByNames(model, {"RightHand"})
    local lul = getPartByNames(model, {"LeftUpperLeg", "Left Leg"})
    local lll = getPartByNames(model, {"LeftLowerLeg"})
    local lfl = getPartByNames(model, {"LeftFoot"})
    local rul = getPartByNames(model, {"RightUpperLeg", "Right Leg"})
    local rll = getPartByNames(model, {"RightLowerLeg"})
    local rfl = getPartByNames(model, {"RightFoot"})

    local segments
    if State.SkeletonType == "Normal" then
        segments = {
            {head, upper},
            {upper, lower},
            {upper, lua or lla or lha},
            {upper, rua or rla or rha},
            {lower, lul or lll or lfl},
            {lower, rul or rll or rfl},
        }
    else
        segments = {
            {head, upper},
            {upper, lower},
            {upper, lua},
            {lua, lla},
            {lla, lha},
            {upper, rua},
            {rua, rla},
            {rla, rha},
            {lower, lul},
            {lul, lll},
            {lll, lfl},
            {lower, rul},
            {rul, rll},
            {rll, rfl},
        }
    end

    local baseThickness = math.clamp(tonumber(State.SkeletonThickness) or 1.6, 1, 8)
    local glowThickness = baseThickness + 2.4
    local index = 1
    for _, seg in ipairs(segments) do
        if index > #rec.Skeleton then break end
        local a = seg[1]
        local b = seg[2]
        if a and b then
            local sa = partToScreen(a)
            local sb = partToScreen(b)
            if sa and sb then
                local gl = rec.SkeletonGlow[index]
                local ln = rec.Skeleton[index]
                gl.Thickness = glowThickness
                ln.Thickness = baseThickness
                if State.ESPGlow then
                    gl.From = sa
                    gl.To = sb
                    gl.Color = color
                    gl.Visible = true
                end
                ln.From = sa
                ln.To = sb
                ln.Color = color
                ln.Visible = true
                index += 1
            end
        end
    end

    local headPos = partToScreen(head)
    if headPos then
        local radius = math.clamp(boxH * 0.11, 4, 18)
        local headThickness = math.max(1.2, baseThickness * 0.95)
        if State.ESPGlow then
            rec.HeadGlow.Position = headPos
            rec.HeadGlow.Radius = radius
            rec.HeadGlow.Color = color
            rec.HeadGlow.Thickness = glowThickness
            rec.HeadGlow.Visible = true
        end
        rec.HeadCircle.Position = headPos
        rec.HeadCircle.Radius = radius
        rec.HeadCircle.Color = color
        rec.HeadCircle.Thickness = headThickness
        rec.HeadCircle.Visible = true
    end
end

local function getAimTarget()
    if not State.CombatEnabled then return nil end
    local center = Vector2.new(Camera.ViewportSize.X * 0.5, Camera.ViewportSize.Y * 0.5)
    local bestPart, bestDistance = nil, math.huge
    local radius = math.max(0, tonumber(State.FOV) or 0)
    local source = (#App.TargetCache > 0 and App.TargetCache) or collectTargets()

    for _, model in ipairs(source) do
        local hum = getHumanoid(model)
        local part = getTargetPart(model)
        if hum and hum.Health > 0 and part and passesWallCheck(model, part) then
            local screenPos, onScreen = Camera:WorldToViewportPoint(part.Position)
            if onScreen and screenPos.Z > 0 then
                local diff = (Vector2.new(screenPos.X, screenPos.Y) - center).Magnitude
                if (radius <= 0 and diff <= 8) or (radius > 0 and diff <= radius) then
                    local metric = diff
                    if State.RenderPriority == "Distance" then
                        local root = getRoot(model)
                        metric = root and distanceTo(root.Position) or diff
                    elseif State.RenderPriority == "Health" then
                        metric = hum.Health
                    end
                    if metric < bestDistance then
                        bestDistance = metric
                        bestPart = part
                    end
                end
            end
        end
    end

    return bestPart
end

local function updateAim()
    if not State.CombatEnabled or not State.AimActive then return end
    local targetPart = getAimTarget()
    if not targetPart then return end

    local camPos = Camera.CFrame.Position
    local desired = CFrame.new(camPos, targetPart.Position)
    local smooth = math.clamp(tonumber(State.Smooth) or 0, 0, 10)

    if smooth <= 0 then
        Camera.CFrame = desired
    else
        local alpha = math.clamp(0.8 / (smooth + 1), 0.04, 0.35)
        Camera.CFrame = Camera.CFrame:Lerp(desired, alpha)
    end
end

local function drawCornerBox(rec, x, y, w, h, color)
    local lenX, lenY = w * 0.24, h * 0.24
    local curveX = math.max(2, lenX * 0.34)
    local curveY = math.max(2, lenY * 0.34)
    local pts = {
        {Vector2.new(x + curveX, y), Vector2.new(x + lenX, y)},
        {Vector2.new(x, y + curveY), Vector2.new(x, y + lenY)},
        {Vector2.new(x + w - lenX, y), Vector2.new(x + w - curveX, y)},
        {Vector2.new(x + w, y + curveY), Vector2.new(x + w, y + lenY)},
        {Vector2.new(x + curveX, y + h), Vector2.new(x + lenX, y + h)},
        {Vector2.new(x, y + h - lenY), Vector2.new(x, y + h - curveY)},
        {Vector2.new(x + w - lenX, y + h), Vector2.new(x + w - curveX, y + h)},
        {Vector2.new(x + w, y + h - lenY), Vector2.new(x + w, y + h - curveY)},
    }
    for i, l in ipairs(rec.Corners) do
        l.From = pts[i][1]
        l.To = pts[i][2]
        l.Color = color
        l.Thickness = 1.5
        l.Visible = true
        local g = rec.CornerGlow[i]
        g.Visible = false
        g.Thickness = 4
        if State.ESPGlow then
            g.From = pts[i][1]
            g.To = pts[i][2]
            g.Color = color
            g.Visible = true
        end
    end

    local curves = {
        {Vector2.new(x + curveX, y), Vector2.new(x, y + curveY)},
        {Vector2.new(x + w - curveX, y), Vector2.new(x + w, y + curveY)},
        {Vector2.new(x, y + h - curveY), Vector2.new(x + curveX, y + h)},
        {Vector2.new(x + w - curveX, y + h), Vector2.new(x + w, y + h - curveY)},
    }
    for i, l in ipairs(rec.CornerRound) do
        l.From = curves[i][1]
        l.To = curves[i][2]
        l.Color = color
        l.Thickness = 1.5
        l.Visible = true
        local g = rec.CornerRoundGlow[i]
        g.Visible = false
        g.Thickness = 4
        if State.ESPGlow then
            g.From = curves[i][1]
            g.To = curves[i][2]
            g.Color = color
            g.Visible = true
        end
    end
end

local function drawName(rec, displayText, x, y, w, color, enabled)
    rec.NameShadow.Visible = false
    rec.NameText.Visible = false
    if not enabled then return end

    local size = math.clamp(tonumber(State.ESPNameSize) or 13, 10, 28)
    local posX = x + (w * 0.5)
    local posY = y - size - 1
    local cache = rec.NameCache or {Text = "", Size = -1, X = -9999, Y = -9999, R = -1, G = -1, B = -1}
    rec.NameCache = cache

    if cache.Text ~= displayText then
        rec.NameText.Text = displayText
        cache.Text = displayText
    end
    if cache.Size ~= size then
        rec.NameText.Size = size
        cache.Size = size
    end
    if math.abs(cache.X - posX) > 0.5 or math.abs(cache.Y - posY) > 0.5 then
        rec.NameText.Position = Vector2.new(posX, posY)
        cache.X = posX
        cache.Y = posY
    end
    local r, g, b = math.floor(color.R * 255 + 0.5), math.floor(color.G * 255 + 0.5), math.floor(color.B * 255 + 0.5)
    if cache.R ~= r or cache.G ~= g or cache.B ~= b then
        rec.NameText.Color = color
        cache.R, cache.G, cache.B = r, g, b
    end
    rec.NameText.Transparency = 1
    rec.NameText.Visible = true
end

local function drawHealth(rec, x, y, w, h, healthPct)
    rec.HealthGlowLine.Visible = false
    rec.HealthBackLine.Visible = false
    rec.HealthLine.Visible = false
    for _, c in ipairs(rec.HealthBackCaps) do c.Visible = false end
    for _, c in ipairs(rec.HealthFillCaps) do c.Visible = false end
    for _, c in ipairs(rec.HealthGlowCaps) do c.Visible = false end
    if not State.HealthBar then return end

    local hpColor = getHealthColor(healthPct)
    local thickness = math.clamp(State.HealthBarThickness or 4, 1, 12)
    local backThickness = thickness + math.max(4, thickness * 0.85)
    local glowThickness = thickness + math.max(8, thickness * 1.8)

    if State.HealthBarSide == "Left" or State.HealthBarSide == "Right" then
        local bx = State.HealthBarSide == "Left" and (x - (thickness + 6)) or (x + w + 6)
        local from = Vector2.new(bx, y + h)
        local to = Vector2.new(bx, y)
        local fillTo = Vector2.new(bx, y + h - (h * healthPct))

        rec.HealthBackLine.From = from
        rec.HealthBackLine.To = to
        rec.HealthBackLine.Color = Color3.fromRGB(10, 10, 14)
        rec.HealthBackLine.Thickness = backThickness
        rec.HealthBackLine.Visible = true

        rec.HealthLine.From = from
        rec.HealthLine.To = fillTo
        rec.HealthLine.Color = hpColor
        rec.HealthLine.Thickness = thickness
        rec.HealthLine.Visible = true

        if State.ESPGlow then
            rec.HealthGlowLine.From = from
            rec.HealthGlowLine.To = fillTo
            rec.HealthGlowLine.Color = hpColor
            rec.HealthGlowLine.Thickness = glowThickness
            rec.HealthGlowLine.Visible = true
        end
    else
        local by = State.HealthBarSide == "Top" and (y - (thickness + 6)) or (y + h + 6)
        local from = Vector2.new(x, by)
        local to = Vector2.new(x + w, by)
        local fillTo = Vector2.new(x + (w * healthPct), by)

        rec.HealthBackLine.From = from
        rec.HealthBackLine.To = to
        rec.HealthBackLine.Color = Color3.fromRGB(18, 18, 22)
        rec.HealthBackLine.Thickness = backThickness
        rec.HealthBackLine.Visible = true

        rec.HealthLine.From = from
        rec.HealthLine.To = fillTo
        rec.HealthLine.Color = hpColor
        rec.HealthLine.Thickness = thickness
        rec.HealthLine.Visible = true

        if State.ESPGlow then
            rec.HealthGlowLine.From = from
            rec.HealthGlowLine.To = fillTo
            rec.HealthGlowLine.Color = hpColor
            rec.HealthGlowLine.Thickness = glowThickness
            rec.HealthGlowLine.Visible = true
        end
    end
end

local function updateESP()
    local live = {}
    local targets = State.ESPEnabled and App.TargetCache or {}
    for rank, target in ipairs(targets) do
        local root = getRoot(target)
        local hum = getHumanoid(target)
        local head = target:FindFirstChild("Head") or getTargetPart(target)
        if root and hum and hum.Health > 0 then
            local dist = distanceTo(root.Position)
            if dist <= State.ESPDistance then
                local pos, onScreen = Camera:WorldToViewportPoint(root.Position)
                if onScreen and pos.Z > 0 then
                    local _, size = target:GetBoundingBox()
                    local scale = 1 / math.max(pos.Z, 1) * 1000
                    local h = math.clamp(size.Y * scale, 26, 300)
                    local w = math.clamp(h * 0.62, 18, 200)
                    local x = pos.X - w/2
                    local y = pos.Y - h/2

                    local rec = App.ESP[target] or createESPRecord(target)
                    live[target] = true
                    local c = State.ESPColor

                    rec.BoxGlow.Visible = false
                    rec.Box.Visible = false
                    rec.LineGlow.Visible = false
                    rec.Line.Visible = false
                    for _, l in ipairs(rec.CornerGlow) do l.Visible = false end
                    for _, l in ipairs(rec.Corners) do l.Visible = false end
                    for _, l in ipairs(rec.CornerRoundGlow) do l.Visible = false end
                    for _, l in ipairs(rec.CornerRound) do l.Visible = false end

                    if State.ESPStyle == "Box" then
                        if State.ESPGlow then
                            rec.BoxGlow.Position = Vector2.new(x, y)
                            rec.BoxGlow.Size = Vector2.new(w, h)
                            rec.BoxGlow.Color = c
                            rec.BoxGlow.Visible = true
                        end

                        rec.Box.Position = Vector2.new(x, y)
                        rec.Box.Size = Vector2.new(w, h)
                        rec.Box.Color = c
                        rec.Box.Visible = true
                    else
                        drawCornerBox(rec, x, y, w, h, c)
                    end

                    if State.Tracers and rank <= State.MaxTracerTargets then
                        local origin = getTracerOrigin()
                        local headPoint = partToScreen(head)
                        if not headPoint then headPoint = Vector2.new(pos.X, y) end
                        if headPoint then
                            if State.ESPGlow then
                                rec.LineGlow.From = origin
                                rec.LineGlow.To = headPoint
                                rec.LineGlow.Color = c
                                rec.LineGlow.Visible = true
                            end

                            rec.Line.From = origin
                            rec.Line.To = headPoint
                            rec.Line.Color = c
                            rec.Line.Visible = true
                        end
                    end

                    drawHealth(rec, x, y, w, h, hum.Health / math.max(hum.MaxHealth, 1))
                    drawSkeleton(rec, target, c, h, State.Skeleton and rank <= State.MaxSkeletonTargets)
                    local nameText = target.Name
                    local owner = Players:GetPlayerFromCharacter(target)
                    if owner then
                        nameText = owner.DisplayName
                    end
                    drawName(rec, nameText, x, y, w, c, State.ESPNames and rank <= State.MaxNameTargets)
                end
            end
        end
    end
    for target, rec in pairs(App.ESP) do
        if not live[target] then
            hideRecord(rec)
            if not target or not target.Parent then
                removeESPRecord(target)
            end
        end
    end
end

