local lib = {}

local TweenService = game:GetService("TweenService")
local UIS = game:GetService("UserInputService")

local theme = {
	bg = Color3.fromRGB(12,12,12),
	panel = Color3.fromRGB(25,25,25),
	accent = Color3.fromRGB(170,85,255),
	text = Color3.fromRGB(240,240,240)
}

function lib:Window(title)

	local gui = Instance.new("ScreenGui")
	gui.Parent = game.CoreGui
	gui.Name = "BenjaHub"

	local main = Instance.new("Frame")
	main.Size = UDim2.new(0,500,0,350)
	main.Position = UDim2.new(.5,-250,.5,-175)
	main.BackgroundColor3 = theme.bg
	main.Parent = gui

	local corner = Instance.new("UICorner")
	corner.Parent = main

	local stroke = Instance.new("UIStroke")
	stroke.Color = theme.accent
	stroke.Thickness = 1.5
	stroke.Parent = main

	local titleLabel = Instance.new("TextLabel")
	titleLabel.Size = UDim2.new(1,0,0,35)
	titleLabel.BackgroundTransparency = 1
	titleLabel.Text = title
	titleLabel.TextColor3 = theme.text
	titleLabel.Font = Enum.Font.GothamBold
	titleLabel.TextSize = 18
	titleLabel.Parent = main

	local container = Instance.new("Frame")
	container.Size = UDim2.new(1,0,1,-40)
	container.Position = UDim2.new(0,0,0,40)
	container.BackgroundTransparency = 1
	container.Parent = main

	local tabs = {}
	local currentY = 10

	function tabs:Tab(name)

		local tab = {}

		local page = Instance.new("Frame")
		page.Size = UDim2.new(1,0,1,0)
		page.BackgroundTransparency = 1
		page.Visible = true
		page.Parent = container

		function tab:Toggle(text,callback)

			local toggle = Instance.new("TextButton")
			toggle.Size = UDim2.new(0,200,0,30)
			toggle.Position = UDim2.new(0,10,0,currentY)
			toggle.BackgroundColor3 = theme.panel
			toggle.Text = text
			toggle.TextColor3 = theme.text
			toggle.Font = Enum.Font.Gotham
			toggle.TextSize = 14
			toggle.Parent = page

			local corner = Instance.new("UICorner")
			corner.Parent = toggle

			local state = false

			toggle.MouseButton1Click:Connect(function()

				state = not state

				TweenService:Create(
					toggle,
					TweenInfo.new(.15),
					{BackgroundColor3 = state and theme.accent or theme.panel}
				):Play()

				callback(state)

			end)

			currentY = currentY + 40

		end

		function tab:Slider(text,min,max,default,callback)

			local slider = Instance.new("Frame")
			slider.Size = UDim2.new(0,200,0,40)
			slider.Position = UDim2.new(0,10,0,currentY)
			slider.BackgroundColor3 = theme.panel
			slider.Parent = page

			local corner = Instance.new("UICorner")
			corner.Parent = slider

			local fill = Instance.new("Frame")
			fill.BackgroundColor3 = theme.accent
			fill.Size = UDim2.new(default/max,0,1,0)
			fill.Parent = slider

			local dragging = false

			slider.InputBegan:Connect(function(input)
				if input.UserInputType == Enum.UserInputType.MouseButton1 then
					dragging = true
				end
			end)

			slider.InputEnded:Connect(function(input)
				if input.UserInputType == Enum.UserInputType.MouseButton1 then
					dragging = false
				end
			end)

			UIS.InputChanged:Connect(function(input)

				if dragging then

					local percent = math.clamp(
						(input.Position.X - slider.AbsolutePosition.X) / slider.AbsoluteSize.X,
						0,1
					)

					fill.Size = UDim2.new(percent,0,1,0)

					local value = math.floor((max-min)*percent+min)

					callback(value)

				end

			end)

			currentY = currentY + 50

		end

		return tab

	end

	return tabs

end

return lib
