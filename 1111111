local function updateWorldExtras(alive)
	PerfStats.VisibleWorld = 0

	if Settings.WorldInvisibleParts then
		local invisibleParts = collectNearbyInvisibleParts(Settings.WorldMaxDistance)
		for i = 1, #invisibleParts do
			local target = invisibleParts[i]
			if isAliveInstance(target) then
				local info = string.format("%dm | T %.2f", math.floor(getDistanceFromLocal(target.Position)), target.Transparency)
				applyVisual(target, target, "InvisiblePart", info, Settings.InvisiblePartFillColor, Color3.fromRGB(255,255,255))
				alive[target] = true
				PerfStats.VisibleWorld = PerfStats.VisibleWorld + 1
			end
		end
	end

	if Settings.WorldPrompts then
		local prompts = collectNearbyPrompts(Settings.WorldMaxDistance)
		for i = 1, #prompts do
			local prompt = prompts[i]
			local root = prompt.Parent
			if root and isAliveInstance(root) then
				local title = prompt.ActionText ~= "" and prompt.ActionText or "Prompt"
				local info = string.format("%dm | %s", math.floor(getDistanceFromLocal(root.Position)), prompt.ObjectText ~= "" and prompt.ObjectText or safeName(root))
				applyVisual(root, root, title, info, Color3.fromRGB(120, 220, 255), Color3.fromRGB(255,255,255))
				alive[root] = true
				PerfStats.VisibleWorld = PerfStats.VisibleWorld + 1
			end
		end
	end

	if Settings.WorldDoors then
		local doors = collectNearbyDoors(Settings.WorldMaxDistance)
		for i = 1, #doors do
			local target = doors[i]
			if isAliveInstance(target) then
				local info = string.format("%dm | Door", math.floor(getDistanceFromLocal(target.Position)))
				applyVisual(target, target, safeName(target), info, Color3.fromRGB(255, 165, 90), Color3.fromRGB(255,255,255))
				alive[target] = true
				PerfStats.VisibleWorld = PerfStats.VisibleWorld + 1
			end
		end
	end
end

local function refreshVisuals(force)
	if not Settings.AutoRefresh and not force then
		return
	end

	local alive = {}
	updateNPCs(alive)
	updateObjects(alive)
	updateSpawns(alive)
	updateTriggers(alive)
	updatePaths(alive)
	updateWorldExtras(alive)

	for target in pairs(Tracked) do
		if not alive[target] then
			removeVisual(target)
		end
	end

	PerfStats.LastRefresh = tick()
end

