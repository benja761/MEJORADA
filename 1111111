local function create(className, props)
    local inst = Instance.new(className)
    for k, v in pairs(props or {}) do
        inst[k] = v
    end
    return inst
end

local function round(n, step)
    step = step or 1
    return math.floor((n / step) + 0.5) * step
end

local function addCorner(obj, r)
    local c = Instance.new("UICorner")
    c.CornerRadius = UDim.new(0, r or 10)
    c.Parent = obj
    return c
end

local function addStroke(obj, color, thickness)
    local s = Instance.new("UIStroke")
    s.Color = color or App.Theme.Stroke
    s.Thickness = thickness or 1
    s.ApplyStrokeMode = Enum.ApplyStrokeMode.Border
    s.Parent = obj
    return s
end

local function addPadding(obj, l, r, t, b)
    local p = Instance.new("UIPadding")
    p.PaddingLeft = UDim.new(0, l or 0)
    p.PaddingRight = UDim.new(0, r or l or 0)
    p.PaddingTop = UDim.new(0, t or l or 0)
    p.PaddingBottom = UDim.new(0, b or t or l or 0)
    p.Parent = obj
    return p
end

local function tween(obj, time, props)
    local tw = TweenService:Create(obj, TweenInfo.new(time, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), props)
    tw:Play()
    return tw
end

local function safeDisconnect(c)
    if c and typeof(c) == "RBXScriptConnection" then c:Disconnect() end
end

local function inputToText(bind)
    if not bind then return "None" end
    return bind.Name or tostring(bind)
end

local function inputMatches(bind, input)
    if not bind or not input or typeof(bind) ~= "EnumItem" then return false end
    if bind.EnumType == Enum.KeyCode then
        return input.KeyCode == bind
    elseif bind.EnumType == Enum.UserInputType then
        return input.UserInputType == bind
    end
    return false
end

local function colorLerp(a, b, t)
    t = math.clamp(t or 0, 0, 1)
    return Color3.new(
        a.R + ((b.R - a.R) * t),
        a.G + ((b.G - a.G) * t),
        a.B + ((b.B - a.B) * t)
    )
end

local function getHealthColor(pct)
    pct = math.clamp(pct or 0, 0, 1)
    local red = Color3.fromRGB(255, 70, 70)
    local yellow = Color3.fromRGB(255, 220, 75)
    local green = Color3.fromRGB(110, 255, 145)
    if pct <= 0.5 then
        return colorLerp(red, yellow, pct / 0.5)
    end
    return colorLerp(yellow, green, (pct - 0.5) / 0.5)
end

local function registerTheme(inst, prop, key)
    App.ThemeRefs[#App.ThemeRefs + 1] = {inst, prop, key}
    inst[prop] = App.Theme[key]
end

local function applyTheme()
    for _, item in ipairs(App.ThemeRefs) do
        if item[1] and item[1].Parent then
            pcall(function() item[1][item[2]] = App.Theme[item[3]] end)
        end
    end
end

local function getCharacter()
    return LocalPlayer.Character
end

local function getHumanoid(model)
    return model and model:FindFirstChildOfClass("Humanoid")
end

local function getRoot(model)
    if not model then return nil end
    if model:IsA("Model") then
        return model:FindFirstChild("HumanoidRootPart") or model.PrimaryPart or model:FindFirstChild("Head")
    elseif model:IsA("BasePart") then
        return model
    end
end

local function localRoot()
    return getRoot(getCharacter())
end

local function distanceTo(pos)
    local root = localRoot()
    if not root then return math.huge end
    return (root.Position - pos).Magnitude
end

local function isAliveModel(model)
    local hum = getHumanoid(model)
    return hum and hum.Health > 0
end

local function worldToViewport(pos)
    return Camera:WorldToViewportPoint(pos)
end

local function getTracerOrigin()
    local size = Camera.ViewportSize
    if State.TracerOrigin == "Top" then
        return Vector2.new(size.X/2, 0)
    elseif State.TracerOrigin == "Center" then
        return Vector2.new(size.X/2, size.Y/2)
    end
    return Vector2.new(size.X/2, size.Y)
end

local function getTargetPart(model)
    if not model then return nil end
    if State.AimPart == "Chest" then
        return model:FindFirstChild("UpperTorso") or model:FindFirstChild("Torso") or model:FindFirstChild("HumanoidRootPart") or model:FindFirstChild("Head") or getRoot(model)
    end
    return model:FindFirstChild(State.AimPart) or model:FindFirstChild("Head") or getRoot(model)
end

local function getCharacterBounds(model)
    local cf, size = model:GetBoundingBox()
    local pos = cf.Position
    local top = select(1, worldToViewport(pos + Vector3.new(0, size.Y/2, 0)))
    local bottom = select(1, worldToViewport(pos - Vector3.new(0, size.Y/2, 0)))
    return cf, size, top, bottom
end

local function createGlowText(parent, text, pos, size, textSize, font, z)
    local holder = create("Frame", {
        BackgroundTransparency = 1,
        Position = pos,
        Size = size,
        ZIndex = z or 5
    })
    holder.Parent = parent

    local layers = {
        {Vector2.new(0, 0), 0, App.Theme.Text},
        {Vector2.new(0, 0), 0.18, App.Theme.Accent},
        {Vector2.new(1, 0), 0.78, App.Theme.Accent},
        {Vector2.new(-1, 0), 0.78, App.Theme.Accent},
        {Vector2.new(0, 1), 0.78, App.Theme.Accent},
        {Vector2.new(0, -1), 0.78, App.Theme.Accent},
        {Vector2.new(2, 0), 0.9, App.Theme.Accent},
        {Vector2.new(-2, 0), 0.9, App.Theme.Accent},
        {Vector2.new(0, 2), 0.9, App.Theme.Accent},
        {Vector2.new(0, -2), 0.9, App.Theme.Accent}
    }

    for _, entry in ipairs(layers) do
        local off, trans, color = entry[1], entry[2], entry[3]
        local glow = create("TextLabel", {
            BackgroundTransparency = 1,
            Position = UDim2.new(0, off.X, 0, off.Y),
            Size = UDim2.new(1,0,1,0),
            Text = text,
            Font = font,
            TextSize = textSize,
            TextTransparency = trans,
            TextColor3 = color,
            TextXAlignment = Enum.TextXAlignment.Left,
            TextYAlignment = Enum.TextYAlignment.Center,
            ZIndex = z or 5
        })
        glow.Parent = holder
    end
    return holder
end

