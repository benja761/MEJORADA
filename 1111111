applyTheme(State.ThemeName)
switchTab("Home")
setGlowVisible(State.Glow)
setBlur(State.Blur)
refreshMenuState()
refreshFovState()
loop()
notify("Loaded", "Panel cargado y ESP con auto-scan listo.")
