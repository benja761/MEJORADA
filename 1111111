				local distance = getDistanceFromLocal(root.Position)
				if distance <= Settings.ObjectMaxDistance then
					local titleText = Settings.ObjectNames and safeName(target) or "Object"
					local info = {}
					if Settings.ObjectDistance then table.insert(info, string.format("%dm", math.floor(distance))) end
					if Settings.ObjectType then table.insert(info, getShortType(target)) end
					applyVisual(target, root, titleText, table.concat(info, " | "), Settings.ObjectFillColor, Settings.ObjectTextColor)
					alive[target] = true
					PerfStats.VisibleObjects = PerfStats.VisibleObjects + 1
				end
			end
		end
	end
end

