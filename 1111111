local function switchTab(name)
	State.CurrentTab = name
	for tabName, data in pairs(Pages) do
		data.Page.Visible = (tabName == name)
	end
	for tabName, btn in pairs(PageButtons) do
		btn.BackgroundColor3 = (tabName == name) and Theme.Accent or Theme.Control
	end
	UI.PageTitle.Text = name
	UI.PageDesc.Text = Pages[name] and Pages[name].Desc or ""
end

local function applySearch()
	local q = string.lower(State.Search or "")
	for _, entry in ipairs(SearchEntries) do
		if entry.Container and entry.Container.Parent and entry.Text then
			local txt = string.lower(tostring(entry.Text() or ""))
			entry.Container.Visible = (q == "") or (string.find(txt, q, 1, true) ~= nil)
		end
	end
end

