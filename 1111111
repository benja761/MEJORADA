local function switchTab(name)
	App.ActiveTab = name

	for pageName, data in pairs(App.Pages) do
		data.Frame.Visible = pageName == name
	end

	for pageName, button in pairs(App.TabButtons) do
		if button and button.Parent then
			button.BackgroundColor3 = (pageName == name) and App.Theme.Section or App.Theme.Panel
		end
	end

	if App.PageTitle then
		App.PageTitle.Text = name
	end

	if App.PageDesc and App.Pages[name] then
		App.PageDesc.Text = App.Pages[name].Description
	end

	refreshSearch()
end

