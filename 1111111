				})
				nameLabel.Parent = holder

				local valueBox = create("TextBox", {
					AnchorPoint = Vector2.new(1, 0),
					Position = UDim2.new(1, -12, 0, 8),
					Size = UDim2.new(0, 58, 0, 20),
					BackgroundColor3 = window.Theme.PanelDark,
					Text = tostring(value),
					TextColor3 = window.Theme.Text,
					TextSize = 12,
					Font = Enum.Font.GothamBold,
					ClearTextOnFocus = false
				})
				valueBox.Parent = holder
				addCorner(valueBox, 8)
				addStroke(valueBox, window.Theme.Outline, 1, 0)

				local descLabel = create("TextLabel", {
					BackgroundTransparency = 1,
					Position = UDim2.new(0, 12, 0, 24),
					Size = UDim2.new(1, -24, 0, 14),
					Text = sliderData.Description or string.format("Min %s • Max %s", tostring(min), tostring(max)),
					TextColor3 = window.Theme.SubText,
					TextSize = 11,
					Font = Enum.Font.Gotham,
					TextXAlignment = Enum.TextXAlignment.Left
				})
				descLabel.Parent = holder

				local bar = create("Frame", {
					BackgroundColor3 = window.Theme.PanelDark,
					BorderSizePixel = 0,
					Position = UDim2.new(0, 12, 0, 46),
					Size = UDim2.new(1, -24, 0, 10)
				})
				bar.Parent = holder
				addCorner(bar, 8)

				local fill = create("Frame", {
					BackgroundColor3 = window.Theme.Accent,
					BorderSizePixel = 0,
					Size = UDim2.new(0, 0, 1, 0)
				})
				fill.Parent = bar
				addCorner(fill, 8)

				local dragging = false

				local function setSlider(newValue)
					newValue = math.clamp(newValue, min, max)
					newValue = round(newValue, decimals)
					value = newValue
					Library.Flags[flag] = newValue
					local percent = (newValue - min) / (max - min)
					fill.Size = UDim2.new(percent, 0, 1, 0)
					valueBox.Text = tostring(newValue) .. suffix
					if sliderData.Callback then
						task.spawn(sliderData.Callback, newValue)
					end
				end

				local function updateFromInput(input)
					local percent = math.clamp((input.Position.X - bar.AbsolutePosition.X) / bar.AbsoluteSize.X, 0, 1)
					local raw = lerp(min, max, percent)
					setSlider(raw)
				end

				window:_trackConnection(bar.InputBegan:Connect(function(input)
					if input.UserInputType == Enum.UserInputType.MouseButton1 then
						dragging = true
						updateFromInput(input)
					end
				end))

				window:_trackConnection(UIS.InputChanged:Connect(function(input)
					if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
						updateFromInput(input)
					end
				end))

				window:_trackConnection(UIS.InputEnded:Connect(function(input)
					if input.UserInputType == Enum.UserInputType.MouseButton1 then
						dragging = false
					end
				end))

				window:_trackConnection(valueBox.FocusLost:Connect(function()
					local numeric = tonumber((valueBox.Text or ""):gsub(suffix, ""))
					if numeric then
						setSlider(numeric)
					else
						valueBox.Text = tostring(value) .. suffix
					end
				end))

				setSlider(value)

				entry.Flag = flag
				entry.Set = setSlider
				entry.Get = function()
					return value
				end

				return {
					Set = function(_, newValue)
						setSlider(newValue)
					end,
					Get = function()
						return value
					end
				}
			end

