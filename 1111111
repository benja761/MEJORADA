local function buildFovCircle()
	App.FovCircle = create("Frame", {
		BackgroundTransparency = 1,
		AnchorPoint = Vector2.new(0.5, 0.5),
		Position = UDim2.new(0.5, 0, 0.5, 0),
		Size = UDim2.new(0, State.AimFov * 2, 0, State.AimFov * 2),
		Visible = State.AimShowFOV,
		Parent = App.Gui
	})
	local corner = Instance.new("UICorner")
	corner.CornerRadius = UDim.new(1, 0)
	corner.Parent = App.FovCircle
	local stroke = Instance.new("UIStroke")
	stroke.Thickness = 1.5
	stroke.Color = App.Theme.Accent
	stroke.Parent = App.FovCircle
	App.FovCircle.UIStroke = stroke
end

local function hookEvents()
	App.SearchBox:GetPropertyChangedSignal("Text"):Connect(function()
		State.Search = App.SearchBox.Text or ""
		refreshSearch()
	end)

	local minimized = false
	local dragActive = false
	local dragStart = nil
	local startPos = nil

	App.MinButton.MouseButton1Click:Connect(function()
		minimized = not minimized
		App.Sidebar.Visible = not minimized
		App.Content.Visible = not minimized
		if minimized then
			App.Root.Size = UDim2.new(0, 1000, 0, 74)
		else
			App.Root.Size = UDim2.new(0, 1000, 0, 640)
		end
	end)

	App.HideButton.MouseButton1Click:Connect(function()
		State.MenuVisible = not State.MenuVisible
		App.Root.Visible = State.MenuVisible
		if App.FovCircle then
			App.FovCircle.Visible = State.AimShowFOV
		end
		if State.Blur then
			setBlur(State.MenuVisible)
		end
	end)

	App.CloseButton.MouseButton1Click:Connect(function()
		cleanupAllRecords()
		if App.BlurObject then
			App.BlurObject:Destroy()
			App.BlurObject = nil
		end
		App.Gui:Destroy()
	end)

	App.Header.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 then
			dragActive = true
			dragStart = input.Position
			startPos = App.Root.Position
			input.Changed:Connect(function()
				if input.UserInputState == Enum.UserInputState.End then
					dragActive = false
				end
			end)
		end
	end)

	UserInputService.InputChanged:Connect(function(input)
		if dragActive and input.UserInputType == Enum.UserInputType.MouseMovement then
			local delta = input.Position - dragStart
			App.Root.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
		end
	end)

	UserInputService.InputBegan:Connect(function(input, gp)
		if gp then
			return
		end
		if input.KeyCode == State.MenuKey then
			State.MenuVisible = not State.MenuVisible
			App.Root.Visible = State.MenuVisible
			if State.Blur then
				setBlur(State.MenuVisible)
			end
		end
	end)

	LocalPlayer.CharacterAdded:Connect(function(char)
		wait(0.4)
		local hum = getHumanoid(char)
		if hum then
			hum.WalkSpeed = State.LocalWalkSpeed
			hum.JumpPower = State.LocalJumpPower
		end
	end)
end

local function updateSelfMarker()
	if not State.ShowSelfMarker then
		cleanupRecord("self_marker")
		return
	end
	local char = LocalPlayer.Character
	local root = getRoot(char)
	if char and root then
		updateRecord("self_marker", char, root, LocalPlayer.DisplayName, "Self", getColorByName("Purple"))
	else
		cleanupRecord("self_marker")
	end
end

local function loop()
	local accum = 0
	RunService.RenderStepped:Connect(function(dt)
		accum = accum + dt
		if App.FovCircle then
			local size = State.AimFov * 2
			App.FovCircle.Size = UDim2.new(0, size, 0, size)
			App.FovCircle.Position = UDim2.new(0.5, 0, 0.5, 0)
			App.FovCircle.Visible = State.AimShowFOV
		end
		if accum >= State.RefreshRate then
			accum = 0
			updateVisualRecords()
			updateSelfMarker()
		end
	end)
end

buildInterface()
buildPages()
buildFovCircle()
hookEvents()
applyTheme(State.ThemeName)
switchTab("Home")
setGlowVisible(State.Glow)
setBlur(State.Blur)
loop()
notify("Loaded", "Premium admin/debug panel loaded correctly.")
