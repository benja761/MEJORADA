--==================================================
-- HELPERS
--==================================================
local function connect(signal, fn)
	local c = signal:Connect(fn)
	table.insert(Connections, c)
	return c
end

local function disconnectAll()
	for _, c in ipairs(Connections) do
		pcall(function()
			c:Disconnect()
		end)
	end
	Connections = {}
end

local function addCorner(obj, radius)
	local c = Instance.new("UICorner")
	c.CornerRadius = UDim.new(0, radius or 8)
	c.Parent = obj
	return c
end

local function addStroke(obj, color, thickness)
	local s = Instance.new("UIStroke")
	s.Color = color
	s.Thickness = thickness or 1
	s.Parent = obj
	return s
end

local function addPadding(obj, left, right, top, bottom)
	local p = Instance.new("UIPadding")
	p.PaddingLeft = UDim.new(0, left or 0)
	p.PaddingRight = UDim.new(0, right or left or 0)
	p.PaddingTop = UDim.new(0, top or left or 0)
	p.PaddingBottom = UDim.new(0, bottom or top or left or 0)
	p.Parent = obj
	return p
end

local function create(className, props)
	local obj = Instance.new(className)
	if props then
		for k, v in pairs(props) do
			obj[k] = v
		end
	end
	return obj
end

local function tween(obj, info, props)
	local tw = TweenService:Create(obj, info, props)
	tw:Play()
	return tw
end

local function getTheme(name)
	return ThemePresets[name] or ThemePresets.Red
end

local function splitCSV(text)
	local results = {}
	for piece in tostring(text or ""):gmatch("[^,]+") do
		piece = piece:gsub("^%s+", ""):gsub("%s+$", "")
		if piece ~= "" then
			table.insert(results, piece)
		end
	end
	return results
end

local function formatColorHex(color)
	return string.format("#%02X%02X%02X", math.floor(color.R * 255), math.floor(color.G * 255), math.floor(color.B * 255))
end

local function getCharacter()
	return LocalPlayer.Character
end

local function getRoot(model)
	if not model then
		return nil
	end
	if model:IsA("BasePart") then
		return model
	end
	if not model:IsA("Model") then
		return nil
	end
	return model:FindFirstChild("HumanoidRootPart")
		or model.PrimaryPart
		or model:FindFirstChild("Head")
		or model:FindFirstChildWhichIsA("BasePart")
end

local function getHumanoid(model)
	if not model or not model:IsA("Model") then
		return nil
	end
	return model:FindFirstChildOfClass("Humanoid")
end

local function getDistanceFromLocal(position)
	local character = getCharacter()
	if not character then
		return math.huge
	end
	local root = character:FindFirstChild("HumanoidRootPart")
	if not root then
		return math.huge
	end
	return (root.Position - position).Magnitude
end

local function getShortType(instance)
	if not instance then
		return "Unknown"
	end
	if instance:IsA("Model") then
		return "Model"
	end
	return instance.ClassName
end

local function safeName(instance)
	if not instance then
		return "Unknown"
	end
	return instance.Name
end

local function getCommonState(target)
	if not target then
		return nil
	end
	local possible = {"State", "AIState", "Status", "Mode"}
	for _, name in ipairs(possible) do
		local attr = target:GetAttribute(name)
		if attr ~= nil then
			return tostring(attr)
		end
		local child = target:FindFirstChild(name)
		if child and child:IsA("StringValue") then
			return child.Value
		end
	end
	local hum = getHumanoid(target)
	if hum then
		return hum:GetState().Name
	end
	return nil
end

local function getCommonTarget(target)
	if not target then
		return nil
	end
	local possible = {"Target", "CurrentTarget", "TargetName"}
	for _, name in ipairs(possible) do
		local attr = target:GetAttribute(name)
		if attr ~= nil then
			return tostring(attr)
		end
		local child = target:FindFirstChild(name)
		if child then
			if child:IsA("ObjectValue") and child.Value then
				return child.Value.Name
			elseif child:IsA("StringValue") then
				return child.Value
			end
		end
	end
	return nil
end

local function isAliveInstance(inst)
	return inst and inst.Parent ~= nil
end

local function setTheme(name)
	Settings.Theme = name
	Theme = getTheme(name)
end

