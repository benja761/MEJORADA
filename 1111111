local function makeDropdown(parent, text, values, defaultValue, callback)
	local current = defaultValue or values[1] or ""
	local holder = create("Frame", {
		Size = UDim2.new(1, 0, 0, 40),
		BackgroundColor3 = Theme.Control,
		BorderSizePixel = 0,
		Parent = parent,
	})
	addCorner(holder, 9)
	addStroke(holder, Theme.Outline, 1)
	registerEntry(holder, { text, table.concat(values, " ") })

	local label = create("TextLabel", {
		BackgroundTransparency = 1,
		Position = UDim2.new(0, 10, 0, 0),
		Size = UDim2.new(0.5, 0, 1, 0),
		Text = text,
		TextColor3 = Theme.Text,
		Font = Enum.Font.GothamBold,
		TextSize = 13,
		TextXAlignment = Enum.TextXAlignment.Left,
		Parent = holder,
	})

	local button = create("TextButton", {
		AnchorPoint = Vector2.new(1, 0.5),
		Position = UDim2.new(1, -10, 0.5, 0),
		Size = UDim2.new(0, 140, 0, 24),
		BackgroundColor3 = Theme.ControlDark,
		BorderSizePixel = 0,
		Text = tostring(current),
		TextColor3 = Theme.Text,
		Font = Enum.Font.GothamBold,
		TextSize = 12,
		AutoButtonColor = false,
		Parent = holder,
	})
	addCorner(button, 7)
	addStroke(button, Theme.Outline, 1)

	local index = 1
	for i, v in ipairs(values) do
		if v == current then
			index = i
			break
		end
	end

	local function setValue(v)
		current = v
		button.Text = tostring(v)
		if callback then callback(v) end
	end

	connect(button.MouseButton1Click, function()
		index = index + 1
		if index > #values then index = 1 end
		setValue(values[index])
	end)

	setValue(current)
	return { Set = setValue, Get = function() return current end, Holder = holder }
end

