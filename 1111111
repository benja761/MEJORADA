local function collectByFolders(csv)
	local out = {}
	local folders = splitCSV(csv)
	for _, name in ipairs(folders) do
		local folder = workspace:FindFirstChild(name)
		if folder then
			for _, child in ipairs(folder:GetChildren()) do
				table.insert(out, child)
			end
		end
	end
	return out
end

local function collectByTag(tag)
	local ok, tagged = pcall(function()
		return CollectionService:GetTagged(tag)
	end)
	if ok and tagged then return tagged end
	return {}
end

local function cappedAppend(dest, source, maxCount, filter)
	for _, item in ipairs(source) do
		if #dest >= maxCount then return end
		if not filter or filter(item) then
			table.insert(dest, item)
		end
	end
end

local function getNPCs()
	local out = {}
	if State.NPCUseTags then
		cappedAppend(out, collectByTag(State.NPCTag), State.MaxTracked, function(v) return v:IsA("Model") end)
	else
		cappedAppend(out, collectByFolders(State.NPCFolders), State.MaxTracked, function(v) return v:IsA("Model") end)
	end
	return out
end

