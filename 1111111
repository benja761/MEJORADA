local function filterEntries(query)
	query = string.lower(query or "")
	for _, entry in ipairs(Registry) do
		local text = entry:GetAttribute("SearchText") or ""
		entry.Visible = (query == "") or (string.find(text, query, 1, true) ~= nil)
	end
end

local function switchTab(name)
	CurrentTab = name
	for tabName, data in pairs(Pages) do
		if data.Page then
			data.Page.Visible = (tabName == name)
		end
	end
	for tabName, button in pairs(TabButtons) do
		button.BackgroundColor3 = (tabName == name) and Theme.Accent or Theme.Control
	end
	PageTitle.Text = name
	PageDesc.Text = (Pages[name] and Pages[name].Desc) or ""
end

