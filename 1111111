local function createToggle(parent, text, getter, setter)
	local holder = create("Frame", {
		BackgroundColor3 = Theme.Control,
		BorderSizePixel = 0,
		Size = UDim2.new(1, 0, 0, 36),
	})
	holder.Parent = parent
	addCorner(holder, 8)
	addStroke(holder, Theme.Outline, 1)

	local label = create("TextLabel", {
		BackgroundTransparency = 1,
		Position = UDim2.new(0, 10, 0, 0),
		Size = UDim2.new(1, -80, 1, 0),
		Text = text,
		TextColor3 = Theme.Text,
		TextXAlignment = Enum.TextXAlignment.Left,
		Font = Enum.Font.GothamBold,
		TextSize = 13,
	})
	label.Parent = holder

	local button = create("TextButton", {
		BackgroundColor3 = Theme.ControlDark,
		BorderSizePixel = 0,
		AnchorPoint = Vector2.new(1,0.5),
		Position = UDim2.new(1, -10, 0.5, 0),
		Size = UDim2.new(0, 54, 0, 24),
		Text = "OFF",
		TextColor3 = Theme.Text,
		Font = Enum.Font.GothamBold,
		TextSize = 12,
		AutoButtonColor = false,
	})
	button.Parent = holder
	addCorner(button, 12)
	addStroke(button, Theme.Outline, 1)

	local function sync()
		local state = getter()
		button.Text = state and "ON" or "OFF"
		button.BackgroundColor3 = state and Theme.Accent or Theme.ControlDark
	end
	connect(button.MouseButton1Click, function()
		setter(not getter())
		sync()
	end)
	sync()
	registerSearch(holder, function() return text end)
	return holder, sync
