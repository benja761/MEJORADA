refreshLobbyCards = function()
    if not App.LobbyGrid then return end
    for _, child in ipairs(App.LobbyGrid:GetChildren()) do
        if child:IsA("Frame") then
            child:Destroy()
        end
    end

    local playersList = Players:GetPlayers()
    table.sort(playersList, function(a, b) return string.lower(a.DisplayName) < string.lower(b.DisplayName) end)

    for order, plr in ipairs(playersList) do
        local card = create("Frame", {BackgroundTransparency=0, BorderSizePixel=0, LayoutOrder=order})
        card.Parent = App.LobbyGrid
