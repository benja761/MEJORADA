end

local function addPadding(obj, left, right, top, bottom)
	local p = Instance.new("UIPadding")
	p.PaddingLeft = UDim.new(0, left or 0)
	p.PaddingRight = UDim.new(0, right or left or 0)
	p.PaddingTop = UDim.new(0, top or left or 0)
	p.PaddingBottom = UDim.new(0, bottom or top or left or 0)
	p.Parent = obj
	return p
end

local function getCharacter()
	return LocalPlayer.Character
end

local function getLocalRoot()
	local ch = getCharacter()
	if not ch then return nil end
	return ch:FindFirstChild("HumanoidRootPart")
end

local function getRoot(model)
	if not model then return nil end
	if model:IsA("BasePart") then
		return model
	end
	if not model:IsA("Model") then
		return nil
	end
	return model:FindFirstChild("HumanoidRootPart") or model.PrimaryPart or model:FindFirstChild("Head") or model:FindFirstChildWhichIsA("BasePart")
end

local function getHumanoid(model)
	if not model or not model:IsA("Model") then return nil end
	return model:FindFirstChildOfClass("Humanoid")
end

local function splitCSV(str)
	local out = {}
	for token in string.gmatch(tostring(str or ""), "[^,]+") do
		token = token:gsub("^%s+", ""):gsub("%s+$", "")
		if token ~= "" then
			table.insert(out, token)
		end
	end
	return out
end

local function countTable(t)
	local n = 0
	for _ in pairs(t) do n = n + 1 end
	return n
end

local function getDistance(pos)
	local root = getLocalRoot()
	if not root then return math.huge end
	return (root.Position - pos).Magnitude
end

local function safeName(instance)
	return instance and instance.Name or "Unknown"
end

local function round(n)
	return math.floor(n + 0.5)
end

local function themeRefresh()
	Theme = Themes[State.ThemeName] or Themes.Red
	if UI.Main then UI.Main.BackgroundColor3 = Theme.Main end
	if UI.Header then UI.Header.BackgroundColor3 = Theme.Panel end
	if UI.LeftPanel then UI.LeftPanel.BackgroundColor3 = Theme.Panel end
	if UI.ContentPanel then UI.ContentPanel.BackgroundColor3 = Theme.Panel end
	if UI.Title then UI.Title.TextColor3 = Theme.Text end
	if UI.PageTitle then UI.PageTitle.TextColor3 = Theme.Text end
	if UI.PageDesc then UI.PageDesc.TextColor3 = Theme.Sub end
	if UI.Search then
		UI.Search.BackgroundColor3 = Theme.ControlDark
		UI.Search.TextColor3 = Theme.Text
		UI.Search.PlaceholderColor3 = Theme.Sub
	end
	for _, button in pairs(PageButtons) do
		button.BackgroundColor3 = Theme.Control
		button.TextColor3 = Theme.Text
	end
	for _, entry in ipairs(SearchEntries) do
		if entry.RefreshTheme then entry.RefreshTheme() end
	end
end

