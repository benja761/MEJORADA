local function setFrameRect(frame, x, y, w, h)
    frame.Position = UDim2.fromOffset(math.floor(x), math.floor(y))
    frame.Size = UDim2.fromOffset(math.max(1, math.floor(w)), math.max(1, math.floor(h)))
end

local function setLineFromTo(line, fromPos, toPos, thickness)
    local dx = toPos.X - fromPos.X
    local dy = toPos.Y - fromPos.Y
    local dist = math.sqrt(dx * dx + dy * dy)
    line.Size = UDim2.fromOffset(math.max(1, dist), thickness or 2)
    line.Position = UDim2.fromOffset((fromPos.X + toPos.X) / 2, (fromPos.Y + toPos.Y) / 2)
    line.Rotation = math.deg(math.atan2(dy, dx))
    line.Visible = true
end

local function getScreenBoundingBox(model)
    if not model or not model.Parent then
        return nil
    end

    local cf, size = model:GetBoundingBox()
    if size.Magnitude <= 0 then
        return nil
    end

    local hx, hy, hz = size.X * 0.5, size.Y * 0.5, size.Z * 0.5
    local corners = {
        Vector3.new(-hx, -hy, -hz), Vector3.new(-hx, -hy, hz),
        Vector3.new(-hx, hy, -hz),  Vector3.new(-hx, hy, hz),
        Vector3.new(hx, -hy, -hz),  Vector3.new(hx, -hy, hz),
        Vector3.new(hx, hy, -hz),   Vector3.new(hx, hy, hz),
    }

    local minX, minY = math.huge, math.huge
    local maxX, maxY = -math.huge, -math.huge
    local anyVisible = false
    local anyFront = false

    for _, offset in ipairs(corners) do
        local world = cf:PointToWorldSpace(offset)
        local view, onScreen = Camera:WorldToViewportPoint(world)
        if view.Z > 0 then
            anyFront = true
            minX = math.min(minX, view.X)
            minY = math.min(minY, view.Y)
            maxX = math.max(maxX, view.X)
            maxY = math.max(maxY, view.Y)
            if onScreen then
                anyVisible = true
            end
        end
    end

    if not anyFront or not anyVisible then
        return nil
    end

    local width = maxX - minX
    local height = maxY - minY
    if width < 2 or height < 2 then
        return nil
    end

    return {
        X = minX,
        Y = minY,
        Width = width,
        Height = height,
        Center = Vector2.new(minX + width * 0.5, minY + height * 0.5),
    }
end

local function getTracerOrigin()
    local center, viewport = getViewportCenter()
    if State.LineOrigin == "Top" then
        return Vector2.new(center.X, 0)
    elseif State.LineOrigin == "Center" then
        return center
    end
    return Vector2.new(center.X, viewport.Y)
end

local function hideRecord(record)
    if not record then
        return
    end
    record.Box.Visible = false
    record.BoxStroke.Enabled = false
    for _, corner in ipairs(record.Corners) do
        corner.Visible = false
    end
    record.Name.Visible = false
    record.Info.Visible = false
    record.Tracer.Visible = false
    record.HealthBack.Visible = false
    record.HealthFill.Visible = false
end

local function makeRecord(id)
    local holder = create("Frame", {
        Parent = App.Overlay,
        BackgroundTransparency = 1,
        BorderSizePixel = 0,
        Size = UDim2.fromScale(1,1),
        Name = "ESP_" .. tostring(id),
    })

    local box = create("Frame", {
        Parent = holder,
        BackgroundTransparency = 1,
        BorderSizePixel = 0,
        Visible = false,
        ZIndex = 4,
    })
    local boxStroke = addStroke(box, State.ESPColor, 1.4)

    local corners = {}
    for i = 1, 8 do
        local c = create("Frame", {
            Parent = holder,
            BorderSizePixel = 0,
            BackgroundColor3 = State.ESPColor,
            Visible = false,
            ZIndex = 4,
        })
        table.insert(corners, c)
    end

    local healthBack = create("Frame", {
        Parent = holder,
        BorderSizePixel = 0,
        BackgroundColor3 = Color3.fromRGB(15,15,15),
        Visible = false,
        ZIndex = 3,
    })
    local healthFill = create("Frame", {
        Parent = holder,
        BorderSizePixel = 0,
        BackgroundColor3 = Color3.fromRGB(80,255,120),
        Visible = false,
        ZIndex = 4,
    })

    local name = createText(holder, 5)
    local info = createText(holder, 5)
    local tracer = createLine(holder, 2)

    local record = {
        Holder = holder,
        Box = box,
        BoxStroke = boxStroke,
        Corners = corners,
        HealthBack = healthBack,
        HealthFill = healthFill,
        Name = name,
        Info = info,
        Tracer = tracer,
    }
    App.Records[id] = record
    return record
end

local function getOrCreateRecord(id)
    return App.Records[id] or makeRecord(id)
end

local function removeRecord(id)
    local record = App.Records[id]
    if record then
        record.Holder:Destroy()
        App.Records[id] = nil
    end
end

local function drawCorners(record, x, y, w, h, color)
    local thickness = math.max(2, math.floor(math.min(w, h) * 0.03))
    local len = math.max(10, math.floor(math.min(w, h) * 0.22))

    local c = record.Corners
    for _, frame in ipairs(c) do
        frame.BackgroundColor3 = color
        frame.Visible = true
    end

    setFrameRect(c[1], x, y, len, thickness)
    setFrameRect(c[2], x, y, thickness, len)

    setFrameRect(c[3], x + w - len, y, len, thickness)
    setFrameRect(c[4], x + w - thickness, y, thickness, len)

    setFrameRect(c[5], x, y + h - thickness, len, thickness)
    setFrameRect(c[6], x, y + h - len, thickness, len)

    setFrameRect(c[7], x + w - len, y + h - thickness, len, thickness)
    setFrameRect(c[8], x + w - thickness, y + h - len, thickness, len)
end

local function clearCorners(record)
    for _, frame in ipairs(record.Corners) do
        frame.Visible = false
    end
end

local function drawHealthBar(record, x, y, w, h, humanoid)
    record.HealthBack.Visible = false
    record.HealthFill.Visible = false
    if not State.ShowHealthBar or not humanoid or humanoid.MaxHealth <= 0 then
        return
    end

    local pct = math.clamp(humanoid.Health / humanoid.MaxHealth, 0, 1)
    local color = getHealthColor(pct)
    local side = State.HealthBarSide

    if side == "Left" then
        setFrameRect(record.HealthBack, x - 6, y, 3, h)
        setFrameRect(record.HealthFill, x - 6, y + (h * (1 - pct)), 3, h * pct)
    elseif side == "Right" then
        setFrameRect(record.HealthBack, x + w + 3, y, 3, h)
        setFrameRect(record.HealthFill, x + w + 3, y + (h * (1 - pct)), 3, h * pct)
    elseif side == "Top" then
        setFrameRect(record.HealthBack, x, y - 6, w, 3)
        setFrameRect(record.HealthFill, x, y - 6, w * pct, 3)
    else
        setFrameRect(record.HealthBack, x, y + h + 3, w, 3)
        setFrameRect(record.HealthFill, x, y + h + 3, w * pct, 3)
    end

    record.HealthFill.BackgroundColor3 = color
    record.HealthBack.Visible = true
    record.HealthFill.Visible = true
end

local function updateRecord(targetId, model, kind)
    local record = getOrCreateRecord(targetId)

    if not State.ESPEnabled or not model or not model.Parent then
        hideRecord(record)
        return false
    end

    local root = getRoot(model)
    local hum = getHumanoid(model)
    if not root then
        hideRecord(record)
        return false
    end

    if hum and hum.Health <= 0 then
        hideRecord(record)
        return false
    end

    local distance = getDistanceFromLocal(root.Position)
    if distance > State.MaxDistance then
        hideRecord(record)
        return false
    end

    local box = getScreenBoundingBox(model)
    if not box then
        hideRecord(record)
        return false
    end

    local color = State.ESPColor
    local x, y, w, h = box.X, box.Y, box.Width, box.Height

    if State.BoxMode == "Box" then
        setFrameRect(record.Box, x, y, w, h)
        record.Box.Visible = true
        record.BoxStroke.Enabled = true
        record.BoxStroke.Color = color
        clearCorners(record)
    else
        record.Box.Visible = false
        record.BoxStroke.Enabled = false
        drawCorners(record, x, y, w, h, color)
    end

    record.Name.Text = model.Name
    record.Name.Position = UDim2.fromOffset(x + (w * 0.5), y - 2)
    record.Name.Visible = State.ShowNames

    if State.ShowDistance then
        record.Info.Text = string.format("%s • %dm", kind, math.floor(distance))
        record.Info.Position = UDim2.fromOffset(x + (w * 0.5), y + h + 16)
        record.Info.Visible = true
    else
        record.Info.Visible = false
    end

    if State.ShowLines then
        local fromPos = getTracerOrigin()
        local toPos = Vector2.new(x + w * 0.5, y + h)
        record.Tracer.BackgroundColor3 = color
        setLineFromTo(record.Tracer, fromPos, toPos, 2)
    else
        record.Tracer.Visible = false
    end

    drawHealthBar(record, x, y, w, h, hum)

    return true
end

local function getNPCModels()
    local results = {}
    local added = {}

    local tagNames = {"NPC", "Enemy", "Mob", "DebugNPC", "Bot"}
    for _, tag in ipairs(tagNames) do
        local tagged = CollectionService:GetTagged(tag)
        for _, item in ipairs(tagged) do
            if item:IsA("Model") and getHumanoid(item) and not added[item] then
                added[item] = true
                table.insert(results, item)
            end
        end
    end

    local folders = {"NPCs", "Enemies", "Mobs", "Bots", "Monsters"}
    for _, folderName in ipairs(folders) do
        local folder = Workspace:FindFirstChild(folderName)
        if folder then
            for _, desc in ipairs(folder:GetDescendants()) do
                if desc:IsA("Model") and getHumanoid(desc) and not Players:GetPlayerFromCharacter(desc) and not added[desc] then
                    added[desc] = true
                    table.insert(results, desc)
                end
            end
        end
    end

    return results
end

local function refreshCandidates(force)
    local now = tick()
    if not force and now - App.CandidateCache.LastRefresh < 1 then
        return
    end
    App.CandidateCache.LastRefresh = now

    local playerModels = {}
    for _, player in ipairs(Players:GetPlayers()) do
        if player ~= LocalPlayer and player.Character and getRoot(player.Character) then
            table.insert(playerModels, player.Character)
        end
    end

    App.CandidateCache.Players = playerModels
    App.CandidateCache.NPCs = getNPCModels()
end

local function cleanupUnused(alive)
    for id in pairs(App.Records) do
        if not alive[id] then
            removeRecord(id)
        end
    end
end

local function updateESP()
    refreshCandidates(false)

    local alive = {}

    if State.ShowPlayers then
        for _, model in ipairs(App.CandidateCache.Players) do
            local id = "player_" .. model:GetFullName()
            if updateRecord(id, model, "Player") then
                alive[id] = true
            end
        end
    end

    if State.ShowNPCs then
        for _, model in ipairs(App.CandidateCache.NPCs) do
            local id = "npc_" .. model:GetFullName()
            if updateRecord(id, model, "NPC") then
                alive[id] = true
            end
        end
    end

    cleanupUnused(alive)
end

