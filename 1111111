		TextSize = 11,
		TextXAlignment = Enum.TextXAlignment.Left
	})
	desc.Parent = holder
	registerTheme(desc, "TextColor3", "SubText")

	local valueLabel = create("TextLabel", {
		BackgroundTransparency = 1,
		AnchorPoint = Vector2.new(1, 0),
		Position = UDim2.new(1, -12, 0, 8),
		Size = UDim2.new(0, 56, 0, 16),
		Text = tostring(defaultValue or min),
		Font = Enum.Font.GothamBold,
		TextSize = 12,
		TextXAlignment = Enum.TextXAlignment.Right
	})
	valueLabel.Parent = holder
	registerTheme(valueLabel, "TextColor3", "Accent")

	local bar = create("Frame", {
		BorderSizePixel = 0,
		Position = UDim2.new(0, 12, 0, 46),
		Size = UDim2.new(1, -24, 0, 10)
	})
	bar.Parent = holder
	registerTheme(bar, "BackgroundColor3", "PanelDark")
	addCorner(bar, 8)

	local fill = create("Frame", {
		BorderSizePixel = 0,
		Size = UDim2.new(0, 0, 1, 0)
	})
	fill.Parent = bar
	registerTheme(fill, "BackgroundColor3", "Accent")
	addCorner(fill, 8)

	local state = defaultValue or min
	local dragging = false

	local function setValue(v)
		local range = max - min
		if range <= 0 then
			range = 1
		end
		v = math.clamp(v, min, max)
		state = round(v)
		local pct = (state - min) / range
		fill.Size = UDim2.new(pct, 0, 1, 0)
		valueLabel.Text = tostring(state)
		if callback then
			callback(state)
		end
	end

	local function updateFromX(x)
		local pct = math.clamp((x - bar.AbsolutePosition.X) / math.max(bar.AbsoluteSize.X, 1), 0, 1)
		local raw = min + ((max - min) * pct)
		setValue(raw)
	end

	bar.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 then
			dragging = true
			updateFromX(input.Position.X)
		end
	end)

	UserInputService.InputChanged:Connect(function(input)
		if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
			updateFromX(input.Position.X)
		end
	end)

	UserInputService.InputEnded:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 then
			dragging = false
		end
	end)

	setValue(state)

	return {
		Set = setValue,
		Get = function()
			return state
		end,
		Holder = holder
	}
end

