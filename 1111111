    addCorner(button, 8)
    addStroke(button, Themes.Stroke, 1)

    local index = 1
    for i, v in ipairs(values) do
        if v == defaultValue then
            index = i
            break
        end
    end

    local function setByIndex(i)
        if i < 1 then i = #values end
        if i > #values then i = 1 end
        index = i
        button.Text = tostring(values[index])
        if callback then
            callback(values[index])
        end
    end

    button.MouseButton1Click:Connect(function()
        setByIndex(index + 1)
    end)

    setByIndex(index)
    return {
        Set = function(v)
            for i, item in ipairs(values) do
                if item == v then
                    setByIndex(i)
                    break
                end
            end
        end,
        Get = function()
            return values[index]
        end
    }
end

