local function addSearchText(container, text)
	container:SetAttribute("SearchText", string.lower(text or ""))
	table.insert(App.VisibleEntries, container)
end

local function refreshSearch()
	local query = string.lower(State.Search or "")
	for i = 1, #App.VisibleEntries do
		local entry = App.VisibleEntries[i]
		if entry and entry.Parent then
			local searchText = entry:GetAttribute("SearchText") or ""
			entry.Visible = (query == "") or (string.find(searchText, query, 1, true) ~= nil)
		end
	end
end

local function cleanupRecord(key)
	local record = App.RecordCache[key]
	if not record then
		return
	end
	if record.Highlight then
		pcall(function()
			record.Highlight:Destroy()
		end)
	end
	if record.Billboard then
		pcall(function()
			record.Billboard:Destroy()
		end)
	end
	App.RecordCache[key] = nil
end

local function cleanupAllRecords()
	for key in pairs(App.RecordCache) do
		cleanupRecord(key)
	end
end

local function makeRecord(key, target)
	local record = App.RecordCache[key]
	if record and record.Target == target then
		return record
	end

	cleanupRecord(key)

	record = {
		Target = target,
		Highlight = nil,
		Billboard = nil,
		Title = nil,
		Info = nil
	}

	App.RecordCache[key] = record

	local highlight = Instance.new("Highlight")
	highlight.Name = "TMHighlight"
	highlight.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
	highlight.FillTransparency = 0.8
	highlight.OutlineTransparency = 0
	highlight.Parent = target
	record.Highlight = highlight

	local billboard = Instance.new("BillboardGui")
	billboard.Name = "TMBillboard"
	billboard.Size = UDim2.new(0, 190, 0, 44)
	billboard.AlwaysOnTop = true
	billboard.StudsOffset = Vector3.new(0, 3, 0)
