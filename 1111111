local function refreshMenuState()
    if not App.Root then
        return
    end

    App.Root.Visible = State.MenuVisible

    if State.MenuMinimized then
        App.Root.Size = UDim2.fromOffset(App.Root.Size.X.Offset, 66)
        App.Sidebar.Visible = false
        App.Content.Visible = false
    else
        App.Root.Size = UDim2.fromOffset(App.Root.Size.X.Offset, 590)
        App.Sidebar.Visible = true
        App.Content.Visible = true
    end

    if App.HotkeyLabel then
        App.HotkeyLabel.Text = "Ocultar: " .. State.MenuKey.Name
    end
end

local function hookMenu()
    local dragging = false
    local dragInput = nil
    local dragStart = nil
    local startPos = nil

    local function beginDrag(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = true
            dragStart = input.Position
            startPos = App.Root.Position

            local changedConn
            changedConn = input.Changed:Connect(function()
                if input.UserInputState == Enum.UserInputState.End then
                    dragging = false
                    dragInput = nil
                    safeDisconnect(changedConn)
                end
            end)
            table.insert(App.Connections, changedConn)
        end
    end

    local function onInputChanged(input)
        if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
            dragInput = input
        end
    end

    table.insert(App.Connections, App.DragHandle.InputBegan:Connect(beginDrag))
    table.insert(App.Connections, App.DragHandle.InputChanged:Connect(onInputChanged))
    table.insert(App.Connections, App.Header.InputBegan:Connect(beginDrag))
    table.insert(App.Connections, App.Header.InputChanged:Connect(onInputChanged))

    table.insert(App.Connections, UserInputService.InputChanged:Connect(function(input)
        if dragging and input == dragInput and dragStart and startPos then
            local delta = input.Position - dragStart
            App.Root.Position = UDim2.fromOffset(startPos.X.Offset + delta.X, startPos.Y.Offset + delta.Y)
        end
    end))

    table.insert(App.Connections, UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = false
            dragInput = nil
        end
    end))

    table.insert(App.Connections, UserInputService.InputBegan:Connect(function(input, gp)
        if input.KeyCode == State.MenuKey then
            State.MenuVisible = not State.MenuVisible
            refreshMenuState()
            return
        end
    end))

    table.insert(App.Connections, App.MinButton.MouseButton1Click:Connect(function()
        State.MenuMinimized = not State.MenuMinimized
        refreshMenuState()
    end))

    table.insert(App.Connections, App.HideButton.MouseButton1Click:Connect(function()
        State.MenuVisible = false
        refreshMenuState()
    end))

    table.insert(App.Connections, App.CloseButton.MouseButton1Click:Connect(function()
        for _, conn in ipairs(App.Connections) do
            safeDisconnect(conn)
        end
        for id in pairs(App.Records) do
            removeRecord(id)
        end
        if App.Gui then
            App.Gui:Destroy()
        end
    end))
end

