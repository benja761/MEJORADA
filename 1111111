		TextSize = 12,
		TextXAlignment = Enum.TextXAlignment.Left
	})
	body.Parent = container
	registerTheme(body, "TextColor3", "SubText")

	local finalHeight = 58
	spawn(function()
		wait(3.2)
		if note.Parent then
			tween(note, TweenInfo.new(0.2, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {BackgroundTransparency = 1, Size = UDim2.new(1, 0, 0, 0)})
