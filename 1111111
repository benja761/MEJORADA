local function getPromptTargets()
	local prompts = Workspace:GetDescendants()
	local results = {}
	local i, inst
	for i = 1, #prompts do
		inst = prompts[i]
		if inst:IsA("ProximityPrompt") then
			results[#results + 1] = inst.Parent or inst
		end
	end
	return results
end

local function getInvisibleTargets()
	local descendants = Workspace:GetDescendants()
	local results = {}
	local i, inst, dist
	for i = 1, #descendants do
		inst = descendants[i]
		if inst:IsA("BasePart") then
			if inst.Transparency >= 0.95 and inst.Size.Magnitude > 1 then
				dist = getDistanceFromLocal(inst.Position)
				if dist <= State.InvisibleMaxDistance then
					results[#results + 1] = inst
					if #results >= math.floor(State.MaxTracked / 2) then
						break
					end
				end
			end
		end
	end
	return results
end

