connect(RunService.RenderStepped, function(dt)
	UpdateAccumulator = UpdateAccumulator + dt
	updateFooter()
	updateSelfMarker()
	applyLocalMovement()

	if UpdateAccumulator >= Settings.RefreshRate then
		UpdateAccumulator = 0
		refreshVisuals(false)
		PerfLabel1.Text = "NPCs Visible: " .. tostring(PerfStats.VisibleNPCs)
		PerfLabel2.Text = "Objects Visible: " .. tostring(PerfStats.VisibleObjects)
		PerfLabel3.Text = "Spawns Visible: " .. tostring(PerfStats.VisibleSpawns)
		PerfLabel4.Text = "Triggers Visible: " .. tostring(PerfStats.VisibleTriggers)
		PerfLabel5.Text = "Path Nodes Visible: " .. tostring(PerfStats.VisiblePaths)
		PerfLabel6.Text = "World Extras Visible: " .. tostring(PerfStats.VisibleWorld)
		PerfLabel7.Text = "Last Refresh: " .. string.format("%.2f", PerfStats.LastRefresh)
	end
end)

