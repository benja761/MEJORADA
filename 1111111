local function processTargets(prefix, targets, options)
	local alive = {}
	local i, target, root, dist, hum, titleText, parts, stateText, targetName, infoText, key, color, count
	count = 0
	for i = 1, #targets do
		target = targets[i]
		if target and target.Parent then
			root = getRoot(target)
			if root then
				dist = getDistanceFromLocal(root.Position)
				if dist <= options.MaxDistance then
					count = count + 1
					if count <= State.MaxTracked then
						titleText = options.DefaultTitle or target.Name
						if options.ShowNames then
							titleText = target.Name
						end
						parts = {}
						if options.ShowDistance then
							parts[#parts + 1] = tostring(math.floor(dist)) .. "m"
						end
						if options.ShowHealth then
							hum = getHumanoid(target)
							if hum then
								parts[#parts + 1] = "HP " .. tostring(math.floor(hum.Health)) .. "/" .. tostring(math.floor(hum.MaxHealth))
							end
						end
						if options.ShowState then
							stateText = getAiState(target)
							if stateText then
								parts[#parts + 1] = stateText
							end
						end
						if options.ShowTarget then
							targetName = getAiTarget(target)
							if targetName then
								parts[#parts + 1] = "T: " .. targetName
							end
						end
						infoText = table.concat(parts, " | ")
						key = prefix .. tostring(target:GetFullName())
						color = getColorByName(options.ColorName)
						updateRecord(key, target, root, titleText, infoText, color)
						alive[key] = true
					end
				end
			end
		end
	end
	return alive
end

