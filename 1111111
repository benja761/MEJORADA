	layout.Parent = scroll

	local state = initial and true or false
	local currentColorName = colorName or "White"
	local expanded = false

	local function updatePopupPosition()
		local pos = colorButton.AbsolutePosition
		local size = colorButton.AbsoluteSize
		popup.Position = UDim2.new(0, pos.X + size.X - 128, 0, pos.Y + size.Y + 4)
	end

	local function setExpanded(v)
		expanded = v and true or false
		popup.Visible = expanded
		if expanded then
			updatePopupPosition()
		end
		popup.Size = UDim2.new(0, 128, 0, expanded and (math.min(#ColorMenus, 7) * 24 + 12) or 0)
	end

	local function setToggle(v)
		state = v and true or false
		check.TextTransparency = state and 0 or 1
		if callbackToggle then
			callbackToggle(state)
		end
	end

	local function setColor(v)
		currentColorName = v
		colorButton.Text = tostring(v)
		colorButton.BackgroundColor3 = getColorByName(v)
		if callbackColor then
			callbackColor(v)
		end
	end

	for i = 1, #ColorMenus do
		local row = create("TextButton", {
