		local function refreshPreview()
			if previewRotationConnection then
				safeDisconnect(previewRotationConnection)
				previewRotationConnection = nil
			end
			if previewClone then
				previewClone:Destroy()
				previewClone = nil
			end

			local character = getCharacter()
			local clone = character:Clone()
			for _, desc in ipairs(clone:GetDescendants()) do
				if desc:IsA("LocalScript") or desc:IsA("Script") then
					desc:Destroy()
				elseif desc:IsA("BasePart") then
					desc.Anchored = true
				elseif desc:IsA("Humanoid") then
					desc.DisplayDistanceType = Enum.HumanoidDisplayDistanceType.None
				end
			end

			local rootPart = clone:FindFirstChild("HumanoidRootPart")
			if rootPart then
				clone:PivotTo(CFrame.new(0, 0, 0))
			end

			clone.Parent = previewViewport
			previewClone = clone

			local attachment = Instance.new("Part")
			attachment.Anchored = true
			attachment.CanCollide = false
			attachment.Transparency = 1
			attachment.Size = Vector3.new(1, 1, 1)
			attachment.Position = Vector3.new(0, 4, 6)
			attachment.Parent = previewViewport
			pointLight.Parent = attachment

			previewCamera.CFrame = CFrame.new(Vector3.new(0, 2, 7), Vector3.new(0, 2, 0))

			previewRotationConnection = RunService.RenderStepped:Connect(function(dt)
				if previewClone and previewClone.Parent then
					previewClone:PivotTo(previewClone:GetPivot() * CFrame.Angles(0, math.rad(20 * dt), 0))
				end
			end)
		end

		refreshPreview()
		characterAddedConnection = LocalPlayer.CharacterAdded:Connect(function()
			task.wait(0.6)
			refreshPreview()
		end)
	end

