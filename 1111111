local function updateRecord(key, target, root, titleText, infoText, color)
	local record = makeRecord(key, target)
	record.Highlight.Adornee = target
	record.Highlight.FillColor = color
	record.Highlight.OutlineColor = color
	record.Billboard.Adornee = root
	record.Title.Text = titleText
	record.Info.Text = infoText
end

local function collectFromFolders(folderNames)
	local results = {}
	for i = 1, #folderNames do
		local folder = Workspace:FindFirstChild(folderNames[i])
		if folder then
			for _, child in ipairs(folder:GetChildren()) do
				if child:IsA("Model") or child:IsA("BasePart") then
					table.insert(results, child)
				end
			end
		end
	end
	return results
end

local function getTagged(tag)
	local ok, results = pcall(function()
		return CollectionService:GetTagged(tag)
	end)
	if ok then
		return results
	end
	return {}
end

local function alreadyAdded(seen, object)
	if seen[object] then
		return true
	end
	seen[object] = true
	return false
end

local function autoScanNPCs()
	local results = {}
	local seen = {}
	for _, inst in ipairs(Workspace:GetDescendants()) do
		if inst:IsA("Model") and inst ~= LocalPlayer.Character then
			local hum = inst:FindFirstChildOfClass("Humanoid")
			local root = getRoot(inst)
			if hum and hum.Health > 0 and root then
				if not alreadyAdded(seen, inst) then
					table.insert(results, inst)
					if #results >= State.MaxTracked then
						break
					end
				end
			end
		end
	end
	return results
end

local objectKeywords = {
	"loot", "pickup", "drop", "cash", "money", "crate", "ammo", "weapon", "item", "bag", "box", "interact"
}

local function nameLooksLikeObject(name)
	name = string.lower(name or "")
	for i = 1, #objectKeywords do
		if string.find(name, objectKeywords[i], 1, true) then
			return true
		end
	end
	return false
end

local function autoScanObjects()
	local results = {}
	local seen = {}

	for _, inst in ipairs(Workspace:GetDescendants()) do
		if #results >= State.MaxTracked then
			break
		end

		if inst:IsA("Model") or inst:IsA("BasePart") then
			local root = getRoot(inst)
			if root and getDistanceFromLocal(root.Position) <= State.ObjectMaxDistance then
				local prompt = inst:FindFirstChildWhichIsA("ProximityPrompt", true)
				local hasMarker = inst:GetAttribute("Interactable") == true
					or inst:GetAttribute("Pickup") == true
					or prompt ~= nil
					or nameLooksLikeObject(inst.Name)

				if hasMarker and not alreadyAdded(seen, inst) then
					table.insert(results, inst)
				end
			end
		end
	end

	return results
end

local function getNpcTargets()
	if State.NpcUseTags then
		local tagged = getTagged(State.NpcTag)
		if #tagged > 0 then
			return tagged
		end
	end

	if State.UseFolderFallback then
		local fromFolders = collectFromFolders({"NPCs", "Enemies", "Mobs", "AI", "Hostiles"})
		if #fromFolders > 0 then
			return fromFolders
		end
	end

	if State.AutoNPCScan then
		return autoScanNPCs()
	end

	return {}
end

local function getObjectTargets()
	if State.ObjectUseTags then
		local tagged = getTagged(State.ObjectTag)
		if #tagged > 0 then
			return tagged
		end
	end

	if State.UseFolderFallback then
		local fromFolders = collectFromFolders({"Loot", "Drops", "Interactive", "Pickups", "Items"})
		if #fromFolders > 0 then
			return fromFolders
		end
	end

	if State.AutoObjectScan then
		return autoScanObjects()
	end

	return {}
end

local function findByNameLike(names, maxItems)
	local results = {}
	local seen = {}
	local lowered = {}
	for i = 1, #names do
		lowered[i] = string.lower(names[i])
	end

	for _, inst in ipairs(Workspace:GetDescendants()) do
		if inst:IsA("Model") or inst:IsA("BasePart") then
			local lname = string.lower(inst.Name)
			for i = 1, #lowered do
				if string.find(lname, lowered[i], 1, true) then
					if not alreadyAdded(seen, inst) then
						table.insert(results, inst)
						if maxItems and #results >= maxItems then
							return results
						end
					end
					break
				end
			end
		end
	end

	return results
end

local function getSpawnTargets()
