    local d = create("TextLabel", {BackgroundTransparency=1, Position=UDim2.new(0,12,0,23), Size=UDim2.new(1,-120,0,14), Text=desc, Font=Enum.Font.Gotham, TextSize=11, TextXAlignment=Enum.TextXAlignment.Left})
    d.Parent = h
    registerTheme(d, "TextColor3", "Sub")

    local b = create("TextButton", {AnchorPoint=Vector2.new(1,0.5), Position=UDim2.new(1,-12,0.5,0), Size=UDim2.new(0,110,0,24), Text=inputToText(default), Font=Enum.Font.GothamBold, TextSize=12, AutoButtonColor=false, BorderSizePixel=0})
    b.Parent = h
    registerTheme(b, "BackgroundColor3", "Main")
    registerTheme(b, "TextColor3", "Text")
    addCorner(b, 8)
    addStroke(b)

    local waiting = false
    local state = default

    local function set(v)
        state = v
        b.Text = inputToText(state)
        if cb then cb(v) end
    end

    b.MouseButton1Click:Connect(function()
        waiting = true
        b.Text = "..."
    end)

    table.insert(App.Connections, UserInputService.InputBegan:Connect(function(input, gp)
        if gp or not waiting then return end
        local picked = nil
        if input.UserInputType == Enum.UserInputType.Keyboard then
            if input.KeyCode and input.KeyCode ~= Enum.KeyCode.Unknown then
                picked = input.KeyCode
            end
        elseif input.UserInputType == Enum.UserInputType.MouseButton1
            or input.UserInputType == Enum.UserInputType.MouseButton2
            or input.UserInputType == Enum.UserInputType.MouseButton3 then
            picked = input.UserInputType
        end
        if picked then
            waiting = false
            set(picked)
        end
    end))

    set(default)
    return {Set=set, Get=function() return state end}
end

