    local state = default
    local currentValues = values or {}

    local function set(v)
        state = v
        b.Text = tostring(v)
        if cb then cb(v) end
    end

    local function rebuildRows()
        for _, child in ipairs(sf:GetChildren()) do
            if child:IsA("TextButton") then
                child:Destroy()
            end
        end
        for _, v in ipairs(currentValues) do
            local row = create("TextButton", {BackgroundTransparency=0, BorderSizePixel=0, Size=UDim2.new(1,0,0,20), Text=tostring(v), Font=Enum.Font.Gotham, TextSize=12, AutoButtonColor=false, ZIndex=101})
