local function collectFromFolders(folderNames)
	local results = {}
	local i, folder, children, c, child
	for i = 1, #folderNames do
		folder = Workspace:FindFirstChild(folderNames[i])
		if folder then
			children = folder:GetChildren()
			for c = 1, #children do
				child = children[c]
				if child:IsA("Model") or child:IsA("BasePart") then
					results[#results + 1] = child
				end
			end
		end
	end
	return results
end

local function getTagged(tag)
	local ok, results = pcall(function()
		return CollectionService:GetTagged(tag)
	end)
	if ok then
		return results
	end
	return {}
end

