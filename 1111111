							TextXAlignment = Enum.TextXAlignment.Left
						})
						optText.Parent = optButton

						if multi then
							local marker = create("TextLabel", {
								BackgroundTransparency = 1,
								AnchorPoint = Vector2.new(1, 0.5),
								Position = UDim2.new(1, -8, 0.5, 0),
								Size = UDim2.new(0, 14, 0, 14),
								Text = selected[option] and "✓" or "",
								TextColor3 = window.Theme.Accent,
								TextSize = 12,
								Font = Enum.Font.GothamBold
							})
							marker.Parent = optButton

							window:_trackConnection(optButton.MouseButton1Click:Connect(function()
								selected[option] = not selected[option]
								marker.Text = selected[option] and "✓" or ""
								choose(option, selected[option])
							end))
						else
							window:_trackConnection(optButton.MouseButton1Click:Connect(function()
								choose(option)
							end))
						end

						table.insert(buttons, optButton)
					end

					updateLabel()
				end

				refreshOptions(values)
				updateLabel()

				entry.Flag = flag
				entry.Get = function()
					return selected
				end
				entry.Set = function(newValue)
					if multi then
						selected = newValue or {}
						Library.Flags[flag] = selected
						refreshOptions(values)
					else
						selected = newValue
						Library.Flags[flag] = selected
						updateLabel()
					end
				end

				return {
					Set = entry.Set,
					Get = entry.Get,
					Refresh = function(_, newValues)
						refreshOptions(newValues)
					end
				}
			end

			function section:AddDropdown(dropData)
				return buildDropdownBase(dropData, false)
			end

			function section:AddMultiDropdown(dropData)
				return buildDropdownBase(dropData, true)
			end

			function section:AddColorPicker(colorData)
				colorData = colorData or {}
				local flag = colorData.Flag or colorData.Name or ("Color_" .. tostring(#window.Registry + 1))
				local value = colorData.Default or window.Theme.Accent
				Library.Flags[flag] = value

				local holder, entry = createItemShell((colorData.Name or "Color Picker") .. " " .. (colorData.Description or ""), 46)

				local nameLabel = create("TextLabel", {
					BackgroundTransparency = 1,
					Position = UDim2.new(0, 12, 0, 8),
					Size = UDim2.new(1, -92, 0, 14),
					Text = colorData.Name or "Color Picker",
					TextColor3 = window.Theme.Text,
					TextSize = 13,
					Font = Enum.Font.GothamBold,
					TextXAlignment = Enum.TextXAlignment.Left
				})
				nameLabel.Parent = holder

				local preview = create("TextButton", {
					AnchorPoint = Vector2.new(1, 0.5),
					Position = UDim2.new(1, -12, 0.5, 0),
					Size = UDim2.new(0, 72, 0, 24),
					BackgroundColor3 = value,
					Text = formatColorHex(value),
					TextColor3 = window.Theme.Text,
					TextSize = 11,
					Font = Enum.Font.GothamBold,
					AutoButtonColor = false
				})
				preview.Parent = holder
				addCorner(preview, 8)
				addStroke(preview, window.Theme.Outline, 1, 0)

				local expanded = false
				local editor = create("Frame", {
					BackgroundColor3 = window.Theme.PanelDark,
					Position = UDim2.new(0, 12, 1, 4),
					Size = UDim2.new(1, -24, 0, 0),
					Visible = false,
					ClipsDescendants = true
				})
				editor.Parent = holder
				addCorner(editor, 8)
				addStroke(editor, window.Theme.Outline, 1, 0)

				local editorLayout = create("UIListLayout", {
					Padding = UDim.new(0, 6),
					SortOrder = Enum.SortOrder.LayoutOrder
				})
				editorLayout.Parent = editor
				addPadding(editor, 8, 8, 8, 8)

				local rBox = create("TextBox", {
					BackgroundColor3 = window.Theme.Section,
					Size = UDim2.new(1, 0, 0, 22),
					Text = tostring(math.floor(value.R * 255)),
					TextColor3 = window.Theme.Text,
					PlaceholderText = "R (0-255)",
					ClearTextOnFocus = false,
					TextSize = 12,
					Font = Enum.Font.Gotham
				})
				rBox.Parent = editor
				addCorner(rBox, 6)
				addStroke(rBox, window.Theme.Outline, 1, 0)
				addPadding(rBox, 8, 8, 0, 0)

				local gBox = rBox:Clone()
				gBox.Text = tostring(math.floor(value.G * 255))
				gBox.PlaceholderText = "G (0-255)"
				gBox.Parent = editor

				local bBox = rBox:Clone()
				bBox.Text = tostring(math.floor(value.B * 255))
				bBox.PlaceholderText = "B (0-255)"
				bBox.Parent = editor

				local hexBox = rBox:Clone()
				hexBox.Text = formatColorHex(value)
				hexBox.PlaceholderText = "#RRGGBB"
				hexBox.Parent = editor

				local palette = create("Frame", {
					BackgroundTransparency = 1,
					Size = UDim2.new(1, 0, 0, 24)
				})
				palette.Parent = editor

				local paletteLayout = create("UIListLayout", {
					FillDirection = Enum.FillDirection.Horizontal,
					Padding = UDim.new(0, 6)
				})
				paletteLayout.Parent = palette

				local swatches = {
					Color3.fromRGB(255, 255, 255),
					Color3.fromRGB(255, 90, 90),
					Color3.fromRGB(255, 180, 70),
					Color3.fromRGB(80, 210, 130),
					Color3.fromRGB(90, 170, 255),
					Color3.fromRGB(170, 85, 255)
				}

				local function setExpanded(state)
					expanded = state
					editor.Visible = state
					holder.Size = UDim2.new(1, 0, 0, state and 154 or 46)
					editor.Size = UDim2.new(1, -24, 0, state and 100 or 0)
				end

				local function setColor(newColor)
					if typeof(newColor) ~= "Color3" then
						return
					end
					value = newColor
					Library.Flags[flag] = value
					preview.BackgroundColor3 = value
					preview.Text = formatColorHex(value)
					rBox.Text = tostring(math.floor(value.R * 255))
					gBox.Text = tostring(math.floor(value.G * 255))
					bBox.Text = tostring(math.floor(value.B * 255))
					hexBox.Text = formatColorHex(value)
					if colorData.Callback then
						task.spawn(colorData.Callback, value)
					end
				end

				local function updateFromRGB()
					local r = math.clamp(tonumber(rBox.Text) or 0, 0, 255)
					local g = math.clamp(tonumber(gBox.Text) or 0, 0, 255)
					local b = math.clamp(tonumber(bBox.Text) or 0, 0, 255)
					setColor(Color3.fromRGB(r, g, b))
				end

				window:_trackConnection(preview.MouseButton1Click:Connect(function()
					setExpanded(not expanded)
				end))

				for _, box in ipairs({ rBox, gBox, bBox }) do
					window:_trackConnection(box.FocusLost:Connect(function()
						updateFromRGB()
					end))
				end

				window:_trackConnection(hexBox.FocusLost:Connect(function()
					local c = colorFromHex(hexBox.Text)
					if c then
						setColor(c)
					else
						hexBox.Text = formatColorHex(value)
					end
				end))

				for _, swatchColor in ipairs(swatches) do
					local swatch = create("TextButton", {
						BackgroundColor3 = swatchColor,
						BorderSizePixel = 0,
						Size = UDim2.new(0, 22, 0, 22),
						Text = "",
						AutoButtonColor = false
					})
					swatch.Parent = palette
					addCorner(swatch, 6)
					addStroke(swatch, window.Theme.Outline, 1, 0)
					window:_trackConnection(swatch.MouseButton1Click:Connect(function()
						setColor(swatchColor)
					end))
				end

				setColor(value)

				entry.Flag = flag
				entry.Set = setColor
				entry.Get = function()
					return value
				end

				return {
					Set = function(_, newColor)
						setColor(newColor)
					end,
					Get = function()
						return value
					end
				}
			end

			table.insert(tab.Sections, section)
			return section
		end

		table.insert(window.Tabs, tab)

		if not window.CurrentTab then
			tab:Show()
		end

		return tab
	end

	local dragging, dragInput, dragStart, startPos

	local function updateDrag(input)
		local delta = input.Position - dragStart
		root.Position = UDim2.new(
			startPos.X.Scale,
			startPos.X.Offset + delta.X,
			startPos.Y.Scale,
			startPos.Y.Offset + delta.Y
		)
	end

	window:_trackConnection(header.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 then
			dragging = true
			dragStart = input.Position
			startPos = root.Position
			window:_trackConnection(input.Changed:Connect(function()
				if input.UserInputState == Enum.UserInputState.End then
					dragging = false
				end
			end))
		end
	end))

	window:_trackConnection(header.InputChanged:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseMovement then
			dragInput = input
		end
	end))

	window:_trackConnection(UIS.InputChanged:Connect(function(input)
		if dragging and input == dragInput then
			updateDrag(input)
		end
	end))

	window:_trackConnection(UIS.InputBegan:Connect(function(input, gp)
		if gp then
			return
		end
		if input.KeyCode == window.ToggleKey then
			window:Toggle()
		end
	end))

	window:_trackConnection(searchBox:GetPropertyChangedSignal("Text"):Connect(function()
		window:ApplySearch()
	end))

	window:_trackConnection(minimizeButton.MouseButton1Click:Connect(function()
		window:SetMinimized(not window.Minimized)
	end))

	window:_trackConnection(hideButton.MouseButton1Click:Connect(function()
		window:Toggle()
	end))

	window:_trackConnection(closeButton.MouseButton1Click:Connect(function()
		window:Destroy()
	end))

	task.defer(function()
		window:Notify({
			Title = title,
			Text = "Window loaded successfully.",
			Type = "Success",
			Duration = 2.6
		})
	end)

	return window
end

return Library

