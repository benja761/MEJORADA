	function window:ApplySearch()
		local query = string.lower(self.SearchBox.Text or "")
		for _, tab in ipairs(self.Tabs) do
			local visibleCount = 0
			for _, section in ipairs(tab.Sections) do
				local sectionVisible = 0
				for _, entry in ipairs(section.Entries) do
					local text = string.lower(entry.SearchText or "")
					local match = query == "" or string.find(text, query, 1, true) ~= nil
					entry.Container.Visible = match
					if match then
						sectionVisible += 1
					end
				end
				section.Container.Visible = sectionVisible > 0 or query == ""
				if section.Container.Visible then
					visibleCount += 1
				end
			end
			tab.VisibleEntryCount = visibleCount
			if tab.Button and tab.CountLabel then
				tab.CountLabel.Text = tostring(visibleCount)
			end
		end
	end

