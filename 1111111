local function setBlur(state)
	State.Blur = state and true or false
	if state then
		if not App.BlurObject then
			App.BlurObject = Instance.new("BlurEffect")
			App.BlurObject.Name = "TonyMontanaBlur"
			App.BlurObject.Size = 0
			App.BlurObject.Parent = Lighting
		end
		App.BlurObject.Enabled = true
		tween(App.BlurObject, TweenInfo.new(0.2, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {Size = 8})
	else
		if App.BlurObject then
			tween(App.BlurObject, TweenInfo.new(0.2, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {Size = 0})
			spawn(function()
				wait(0.2)
				if App.BlurObject then
					App.BlurObject.Enabled = false
				end
			end)
		end
	end
end

local function setGlowVisible(state)
	State.Glow = state and true or false
	local i, holder
	if App.GlowHolders then
		for i = 1, #App.GlowHolders do
			holder = App.GlowHolders[i]
			if holder and holder.Parent then
				holder.Visible = State.Glow
			end
		end
	end
end

local function makeTrackedGlow(parent, role)
	if not App.GlowHolders then
		App.GlowHolders = {}
	end
	local glow = makeGlow(parent, role)
	table.insert(App.GlowHolders, glow)
	return glow
end

local function addSearchText(container, text)
	container:SetAttribute("SearchText", string.lower(text or ""))
	table.insert(App.VisibleEntries, container)
end

local function refreshSearch()
	local query = string.lower(State.Search or "")
	local i, entry, searchText, show
	for i = 1, #App.VisibleEntries do
		entry = App.VisibleEntries[i]
		if entry and entry.Parent then
			searchText = entry:GetAttribute("SearchText") or ""
			show = (query == "") or (string.find(searchText, query, 1, true) ~= nil)
			entry.Visible = show
		end
	end
end

