local function getWorldPrompts()
	local out = {}
	for _, d in ipairs(workspace:GetDescendants()) do
		if #out >= State.MaxTracked then break end
		if d:IsA("ProximityPrompt") then
			table.insert(out, d)
		end
	end
	return out
end

local function getInvisibleParts()
	local out = {}
	for _, d in ipairs(workspace:GetDescendants()) do
		if #out >= State.MaxTracked then break end
		if d:IsA("BasePart") and d.Transparency >= State.InvisibleThreshold and d.Name ~= "HumanoidRootPart" then
			table.insert(out, d)
		end
	end
	return out
end

local function setVisual(target, adornee, color, title, info)
	local rec = ensureVisual(target)
	rec.Highlight.Adornee = target
	rec.Highlight.FillColor = color
	rec.Highlight.OutlineColor = color
	rec.Title.Text = title or safeName(target)
	rec.Info.Text = info or ""
	rec.Title.TextColor3 = State.TextColor
	rec.Info.TextColor3 = State.TextColor
	rec.Billboard.Adornee = adornee or getRoot(target)
end

local function refreshVisuals()
	Stats.VisibleNPCs = 0
	Stats.VisibleObjects = 0
	Stats.VisibleSpawns = 0
	Stats.VisibleTriggers = 0
	Stats.VisiblePaths = 0
	Stats.VisibleWorld = 0

	local alive = {}

	if State.NPCEnabled then
		for _, npc in ipairs(getNPCs()) do
			local root = getRoot(npc)
			if root then
				local dist = getDistance(root.Position)
				if dist <= State.NPCMaxDistance then
					alive[npc] = true
					local hum = getHumanoid(npc)
					local parts = {}
					if State.NPCDistance then table.insert(parts, tostring(round(dist)) .. "m") end
					if State.NPCHealth and hum then table.insert(parts, "HP " .. tostring(round(hum.Health)) .. "/" .. tostring(round(hum.MaxHealth))) end
					setVisual(npc, root, State.NPCColor, State.NPCNames and safeName(npc) or "NPC", table.concat(parts, " | "))
					Stats.VisibleNPCs = Stats.VisibleNPCs + 1
				end
			end
		end
	end

	if State.ObjectsEnabled then
		for _, obj in ipairs(getObjects()) do
			local root = getRoot(obj)
			if root then
				local dist = getDistance(root.Position)
				if dist <= State.ObjectMaxDistance then
					alive[obj] = true
					local parts = {}
					if State.ObjectDistance then table.insert(parts, tostring(round(dist)) .. "m") end
					setVisual(obj, root, State.ObjectColor, State.ObjectNames and safeName(obj) or "Object", table.concat(parts, " | "))
					Stats.VisibleObjects = Stats.VisibleObjects + 1
				end
			end
		end
	end

	if State.SpawnsEnabled then
		for _, obj in ipairs(getSpawns()) do
			local root = getRoot(obj)
			if root then
				local dist = getDistance(root.Position)
				if dist <= State.SpawnMaxDistance then
					alive[obj] = true
					setVisual(obj, root, State.SpawnColor, "Spawn", tostring(round(dist)) .. "m")
					Stats.VisibleSpawns = Stats.VisibleSpawns + 1
				end
			end
		end
	end

	if State.TriggersEnabled then
		for _, obj in ipairs(getTriggers()) do
			local root = getRoot(obj)
			if root then
				local dist = getDistance(root.Position)
				if dist <= State.TriggerMaxDistance then
					alive[obj] = true
					setVisual(obj, root, State.TriggerColor, "Trigger", tostring(round(dist)) .. "m")
					Stats.VisibleTriggers = Stats.VisibleTriggers + 1
				end
			end
		end
	end

	if State.PathsEnabled then
		for _, obj in ipairs(getPaths()) do
			local root = getRoot(obj)
			if root then
				local dist = getDistance(root.Position)
				if dist <= State.PathMaxDistance then
					alive[obj] = true
					setVisual(obj, root, State.PathColor, "Path Node", tostring(round(dist)) .. "m")
					Stats.VisiblePaths = Stats.VisiblePaths + 1
				end
			end
		end
	end

	if State.PromptsEnabled then
		for _, prompt in ipairs(getWorldPrompts()) do
			local parent = prompt.Parent
			local root = parent and (parent:IsA("BasePart") and parent or getRoot(parent))
			if root then
				local dist = getDistance(root.Position)
				if dist <= State.WorldMaxDistance then
					alive[prompt] = true
					setVisual(prompt, root, Theme.Warn, prompt.ActionText ~= "" and prompt.ActionText or "Prompt", tostring(round(dist)) .. "m")
					Stats.VisibleWorld = Stats.VisibleWorld + 1
				end
			end
		end
	end

	if State.InvisiblePartsEnabled then
		for _, part in ipairs(getInvisibleParts()) do
			local dist = getDistance(part.Position)
			if dist <= State.WorldMaxDistance then
				alive[part] = true
				setVisual(part, part, State.InvisibleColor, "Invisible", tostring(round(dist)) .. "m")
				Stats.VisibleWorld = Stats.VisibleWorld + 1
			end
		end
	end

	for target in pairs(Tracked) do
		if not alive[target] then
			cleanupTarget(target)
		end
	end

	Stats.LastRefresh = tick()
end

