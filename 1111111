local function inputToText(bind)
    if not bind then return "None" end
    return bind.Name or tostring(bind)
end

local function inputMatches(bind, input)
    if not bind or not input or typeof(bind) ~= "EnumItem" then return false end
    if bind.EnumType == Enum.KeyCode then
        return input.KeyCode == bind
    elseif bind.EnumType == Enum.UserInputType then
        return input.UserInputType == bind
    end
    return false
end

local function colorLerp(a, b, t)
    t = math.clamp(t or 0, 0, 1)
    return Color3.new(
        a.R + ((b.R - a.R) * t),
        a.G + ((b.G - a.G) * t),
        a.B + ((b.B - a.B) * t)
    )
end

local function getHealthColor(pct)
    pct = math.clamp(pct or 0, 0, 1)
    local red = Color3.fromRGB(255, 46, 46)
    local orange = Color3.fromRGB(255, 132, 54)
    local yellow = Color3.fromRGB(255, 224, 74)
    local lime = Color3.fromRGB(175, 255, 92)
    local green = Color3.fromRGB(82, 255, 132)
    if pct <= 0.25 then
        return colorLerp(red, orange, pct / 0.25)
    elseif pct <= 0.5 then
        return colorLerp(orange, yellow, (pct - 0.25) / 0.25)
    elseif pct <= 0.75 then
        return colorLerp(yellow, lime, (pct - 0.5) / 0.25)
    end
    return colorLerp(lime, green, (pct - 0.75) / 0.25)
end

local function registerTheme(inst, prop, key)
    App.ThemeRefs[#App.ThemeRefs + 1] = {inst, prop, key}
    inst[prop] = App.Theme[key]
end

local function applyTheme()
    for _, item in ipairs(App.ThemeRefs) do
        if item[1] and item[1].Parent then
            pcall(function() item[1][item[2]] = App.Theme[item[3]] end)
        end
    end
    if App.FOVCircle then
        local stroke = App.FOVCircle:FindFirstChildOfClass("UIStroke")
        if stroke then
            stroke.Color = App.Theme.Accent
        end
    end
    if App.HeaderLight then
        App.HeaderLight.BackgroundColor3 = App.Theme.AccentSoft
    end
    if App.HeaderBloom then
        App.HeaderBloom.BackgroundColor3 = App.Theme.Accent
    end
end

local function rebuildThemeColors()
    local accent = State.MenuColor or Color3.fromRGB(245, 245, 255)
    local textColor = State.MenuTextColor or Color3.fromRGB(255, 255, 255)
    App.Theme.Accent = accent
    App.Theme.AccentSoft = colorLerp(accent, Color3.fromRGB(255, 255, 255), 0.38)
    App.Theme.Text = textColor
    App.Theme.Sub = colorLerp(textColor, Color3.fromRGB(118, 118, 128), 0.58)
    App.Theme.Main = colorLerp(Color3.fromRGB(9, 9, 12), accent, 0.07)
    App.Theme.Panel = colorLerp(Color3.fromRGB(17, 17, 22), accent, 0.11)
    App.Theme.Panel2 = colorLerp(Color3.fromRGB(24, 24, 31), accent, 0.16)
    App.Theme.Stroke = colorLerp(Color3.fromRGB(44, 44, 54), accent, 0.24)
    applyTheme()
end

