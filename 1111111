rebuildPreview = function()
    clearPreview()
    if not App.Viewport or not State.CharacterPreview then
        if App.PreviewWindow then App.PreviewWindow.Visible = false end
        return
    end

    App.PreviewWindow.Visible = State.MenuVisible
    local world = Instance.new("WorldModel")
    world.Parent = App.Viewport
    App.PreviewWorld = world

    local char = getCharacter()
    if not char then return end
    local clone = char:Clone()
    for _, v in ipairs(clone:GetDescendants()) do
        if v:IsA("LocalScript") or v:IsA("Script") then
            v:Destroy()
        elseif v:IsA("BasePart") then
            v.Anchored = true
            v.CanCollide = false
        end
    end
    clone.Parent = world
    App.PreviewClone = clone

    local cam = Instance.new("Camera")
    cam.Parent = App.Viewport
    App.Viewport.CurrentCamera = cam

    local root = getRoot(clone)
    if root then
        cam.CFrame = CFrame.new(root.Position + Vector3.new(2, 1.2, 6), root.Position + Vector3.new(0, 1, 0))
    else
        cam.CFrame = CFrame.new(Vector3.new(0, 2, 6), Vector3.new(0, 1, 0))
    end

    local light = Instance.new("PointLight")
    light.Brightness = 1.5
    light.Range = 20
    light.Parent = cam
end

