	function window:SaveConfig(name)
		if not writefile then
			self:Notify({ Title = "Config", Text = "writefile is not available in this environment.", Type = "Warning" })
			return false
		end

		ensureFolder("TonyMontanaConfigs")
		ensureFolder("TonyMontanaConfigs/" .. self.ConfigFolder)

		local data = {}
		for flag, value in pairs(Library.Flags) do
			data[flag] = serializeColor(value)
		end

		local path = ("TonyMontanaConfigs/%s/%s.json"):format(self.ConfigFolder, sanitizeFileName(name or "default"))
		saveFile(path, HttpService:JSONEncode(data))
		self:Notify({ Title = "Config", Text = "Saved config: " .. (name or "default"), Type = "Success" })
		return true
	end

	function window:LoadConfig(name)
		if not readfile then
			self:Notify({ Title = "Config", Text = "readfile is not available in this environment.", Type = "Warning" })
			return false
		end

		local path = ("TonyMontanaConfigs/%s/%s.json"):format(self.ConfigFolder, sanitizeFileName(name or "default"))
		local raw = readFile(path)
		if not raw then
			self:Notify({ Title = "Config", Text = "Config not found: " .. (name or "default"), Type = "Error" })
			return false
		end

		local ok, decoded = pcall(function()
			return HttpService:JSONDecode(raw)
		end)

		if not ok or typeof(decoded) ~= "table" then
			self:Notify({ Title = "Config", Text = "Invalid config file.", Type = "Error" })
			return false
		end

		for _, entry in ipairs(self.Registry) do
			if entry.Flag and decoded[entry.Flag] ~= nil and entry.Set then
				entry.Set(deserializeColor(decoded[entry.Flag]))
			end
		end

		self:Notify({ Title = "Config", Text = "Loaded config: " .. (name or "default"), Type = "Success" })
		return true
	end

	function window:GetConfigs()
		local results = {}
		if listfiles and isfolder and isfolder("TonyMontanaConfigs/" .. self.ConfigFolder) then
			for _, file in ipairs(listfiles("TonyMontanaConfigs/" .. self.ConfigFolder)) do
				local name = file:match("([^\\/]+)%.json$")
				if name then
					table.insert(results, name)
				end
			end
		end
		table.sort(results)
		return results
	end

