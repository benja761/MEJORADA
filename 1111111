-- DATA COLLECTION
--==================================================
local function collectFromFolders(csv)
	local results = {}
	for _, folderName in ipairs(splitCSV(csv)) do
		local folder = workspace:FindFirstChild(folderName)
		if folder then
			for _, child in ipairs(folder:GetChildren()) do
				if child:IsA("Model") or child:IsA("BasePart") then
					table.insert(results, child)
				end
			end
		end
	end
	return results
end

local function collectByTagOrFolder(useTags, tag, folders)
	local results = {}
	if useTags then
		for _, inst in ipairs(CollectionService:GetTagged(tag)) do
			if inst:IsA("Model") or inst:IsA("BasePart") then
				table.insert(results, inst)
			end
		end
	else
		results = collectFromFolders(folders)
	end
	return results
end

local function collectNearbyInvisibleParts(maxDistance)
	local results = {}
	for _, inst in ipairs(workspace:GetDescendants()) do
		if inst:IsA("BasePart") and inst.Transparency >= Settings.InvisibleTransparencyThreshold and inst.Transparency < 1 then
			local distance = getDistanceFromLocal(inst.Position)
			if distance <= maxDistance then
				table.insert(results, inst)
				if #results >= Settings.MaxTrackedPerGroup then
					break
				end
			end
		end
	end
	return results
end

local function collectNearbyPrompts(maxDistance)
	local results = {}
	for _, inst in ipairs(workspace:GetDescendants()) do
		if inst:IsA("ProximityPrompt") then
			local parent = inst.Parent
			if parent and parent:IsA("BasePart") then
				local distance = getDistanceFromLocal(parent.Position)
				if distance <= maxDistance then
					table.insert(results, inst)
					if #results >= Settings.MaxTrackedPerGroup then
						break
					end
				end
			end
		end
	end
	return results
end

local function collectNearbyDoors(maxDistance)
	local results = {}
	for _, inst in ipairs(workspace:GetDescendants()) do
		if inst:IsA("BasePart") then
			local lower = string.lower(inst.Name)
			if string.find(lower, "door", 1, true) then
				local distance = getDistanceFromLocal(inst.Position)
				if distance <= maxDistance then
					table.insert(results, inst)
					if #results >= Settings.MaxTrackedPerGroup then
						break
					end
				end
			end
		end
	end
	return results
end

--==================================================
