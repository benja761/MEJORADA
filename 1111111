local function makeToggle(parent, text, defaultValue, callback)
	local state = defaultValue and true or false
	local holder = create("Frame", {
		Size = UDim2.new(1, 0, 0, 38),
		BackgroundColor3 = Theme.Control,
		BorderSizePixel = 0,
		Parent = parent,
	})
