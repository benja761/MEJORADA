--==================================================
-- DRAG / WINDOW ACTIONS
--==================================================
local dragging = false
local dragStart = nil
local startPos = nil

connect(Header.InputBegan, function(input)
	if input.UserInputType == Enum.UserInputType.MouseButton1 then
		dragging = true
		dragStart = input.Position
		startPos = Main.Position
		connect(input.Changed, function()
			if input.UserInputState == Enum.UserInputState.End then
				dragging = false
			end
		end)
	end
end)

connect(UserInputService.InputChanged, function(input)
	if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
		local delta = input.Position - dragStart
		Main.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
	end
end)

connect(CloseBtn.MouseButton1Click, function()
	clearAllVisuals()
	disconnectAll()
	ScreenGui:Destroy()
end)

connect(HideBtn.MouseButton1Click, function()
	Main.Visible = false
end)

connect(MinBtn.MouseButton1Click, function()
	Settings.Minimized = not Settings.Minimized
	Sidebar.Visible = not Settings.Minimized
	Content.Visible = not Settings.Minimized
	Footer.Visible = not Settings.Minimized
	Main.Size = Settings.Minimized and UDim2.new(0, 980, 0, 48) or UDim2.new(0, 980, 0, 620)
end)

connect(UserInputService.InputBegan, function(input, gp)
	if gp then return end
	if input.KeyCode == Settings.MenuKey then
		Main.Visible = not Main.Visible
	end
end)

--==================================================
-- FOOTER / PLAYER UPDATE
--==================================================
local function updateFooter()
	local parts = {}
	table.insert(parts, "Tracked " .. tostring((function() local n=0 for _ in pairs(Tracked) do n=n+1 end return n end)()))
	table.insert(parts, "Refresh " .. string.format("%.2f", Settings.RefreshRate))

	if Settings.SelfStats then
		local char = getCharacter()
		local hum = char and char:FindFirstChildOfClass("Humanoid")
		if hum then
			table.insert(parts, "HP " .. math.floor(hum.Health) .. "/" .. math.floor(hum.MaxHealth))
		end
	end

	if Settings.SelfVelocity then
		local char = getCharacter()
		local root = char and char:FindFirstChild("HumanoidRootPart")
		if root then
			table.insert(parts, "Vel " .. math.floor(root.AssemblyLinearVelocity.Magnitude))
		end
	end

	Footer.Text = table.concat(parts, "   •   ")
end

local function updateSelfMarker()
	if not Settings.SelfRootMarker then
		local char = getCharacter()
		local root = char and char:FindFirstChild("HumanoidRootPart")
		if root then removeVisual(root) end
		return
	end
	local char = getCharacter()
	local root = char and char:FindFirstChild("HumanoidRootPart")
	if root then
		applyVisual(root, root, "SelfRoot", string.format("%dm", math.floor(getDistanceFromLocal(root.Position))), Theme.Accent, Color3.fromRGB(255,255,255))
	end
end

local function applyLocalMovement()
	if not Settings.LocalMovementOverride then
		return
	end
	local char = getCharacter()
	local hum = char and char:FindFirstChildOfClass("Humanoid")
	if hum then
		hum.WalkSpeed = Settings.WalkSpeed
		hum.JumpPower = Settings.JumpPower
	end
end

