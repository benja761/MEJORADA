local function getPromptTargets()
	local results = {}
	for _, inst in ipairs(Workspace:GetDescendants()) do
		if inst:IsA("ProximityPrompt") then
			table.insert(results, inst.Parent or inst)
			if #results >= State.MaxTracked then
				break
			end
		end
	end
	return results
end

local function getInvisibleTargets()
	local results = {}
	for _, inst in ipairs(Workspace:GetDescendants()) do
		if inst:IsA("BasePart") then
			if inst.Transparency >= 0.95 and inst.Size.Magnitude > 1 then
				if getDistanceFromLocal(inst.Position) <= State.InvisibleMaxDistance then
					table.insert(results, inst)
					if #results >= math.floor(State.MaxTracked / 2) then
						break
					end
				end
			end
		end
	end
	return results
end

local function getAiState(model)
	local stateValue = model and model:FindFirstChild("State")
	if stateValue and stateValue:IsA("StringValue") then
		return stateValue.Value
	end
	return nil
end

local function getAiTarget(model)
	local targetValue = model and model:FindFirstChild("Target")
	if targetValue and targetValue.Value then
		return targetValue.Value.Name
	end
	return nil
end

local function processTargets(prefix, targets, options)
	local alive = {}
	local count = 0

	for i = 1, #targets do
		local target = targets[i]
		if target and target.Parent then
			local root = getRoot(target)
			if root then
				local dist = getDistanceFromLocal(root.Position)
				if dist <= options.MaxDistance then
					count = count + 1
					if count <= State.MaxTracked then
						local titleText = options.ShowNames and target.Name or (options.DefaultTitle or target.Name)
						local parts = {}

						if options.ShowDistance then
							table.insert(parts, tostring(math.floor(dist)) .. "m")
						end

						if options.ShowHealth then
							local hum = getHumanoid(target)
							if hum then
								table.insert(parts, "HP " .. tostring(math.floor(hum.Health)) .. "/" .. tostring(math.floor(hum.MaxHealth)))
							end
						end

						if options.ShowState then
							local stateText = getAiState(target)
							if stateText and stateText ~= "" then
								table.insert(parts, stateText)
							end
						end

						if options.ShowTarget then
							local tname = getAiTarget(target)
							if tname and tname ~= "" then
								table.insert(parts, "T: " .. tname)
							end
						end

						local infoText = table.concat(parts, " | ")
						local key = prefix .. target:GetDebugId()
						updateRecord(key, target, root, titleText, infoText, getColorByName(options.ColorName))
						alive[key] = true
					end
				end
			end
		end
	end

	return alive
end

local function updateVisualRecords()
	local alive = {}

	if State.NpcESP then
		local block = processTargets("npc_", getNpcTargets(), {
			ShowNames = State.NpcNames,
			ShowDistance = State.NpcDistance,
			ShowHealth = State.NpcHealth,
			ShowState = State.NpcState,
			ShowTarget = State.NpcTarget,
			ColorName = State.NpcColor,
			MaxDistance = State.NpcMaxDistance,
			DefaultTitle = "NPC"
		})
		for key in pairs(block) do alive[key] = true end
	end

	if State.ObjectESP then
		local block = processTargets("obj_", getObjectTargets(), {
			ShowNames = State.ObjectNames,
