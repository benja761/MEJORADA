local function serializeColor3(c)
    return {R = c.R, G = c.G, B = c.B}
end

local function deserializeColor3(t)
    if typeof(t) == "Color3" then return t end
    if type(t) == "table" and t.R and t.G and t.B then
        return Color3.new(t.R, t.G, t.B)
    end
    return State.ESPColor
end

local function serializeBind(bind)
    if typeof(bind) ~= "EnumItem" then return nil end
    return {EnumType = bind.EnumType.Name, Name = bind.Name}
end

local function deserializeBind(data, fallback)
    if typeof(data) == "EnumItem" then return data end
    if type(data) ~= "table" then return fallback end
    if data.EnumType == "KeyCode" and Enum.KeyCode[data.Name] then
        return Enum.KeyCode[data.Name]
    elseif data.EnumType == "UserInputType" and Enum.UserInputType[data.Name] then
        return Enum.UserInputType[data.Name]
    end
    return fallback
end

local function canUseFiles()
    return typeof(writefile) == "function" and typeof(readfile) == "function" and typeof(isfile) == "function" and typeof(listfiles) == "function"
end

local function ensureConfigFolder()
    if typeof(makefolder) == "function" and typeof(isfolder) == "function" and not isfolder("NexhideraConfigs") then
        pcall(makefolder, "NexhideraConfigs")
    end
end

local function listConfigNames()
    if not canUseFiles() then
        return {"default"}
    end
    ensureConfigFolder()
    local out, seen = {}, {}
    local ok, files = pcall(listfiles, "NexhideraConfigs")
    if ok and type(files) == "table" then
        for _, file in ipairs(files) do
            local name = string.match(file, "([^/\]+)%.json$")
            if name and not seen[name] then
                seen[name] = true
                table.insert(out, name)
            end
        end
    end
    table.sort(out, function(a, b) return string.lower(a) < string.lower(b) end)
    if #out == 0 then
        out = {"default"}
    end
    return out
end

local function getConfigPath(name)
    local clean = tostring(name or "default"):gsub("[^%w_%-]", "_")
    if clean == "" then clean = "default" end
    return clean, ("NexhideraConfigs/%s.json"):format(clean)
end

local function applyLoadedState(data)
    local color = deserializeColor3(data.ESPColor)
    local menuColor = deserializeColor3(data.MenuColor or State.MenuColor)
    local menuTextColor = deserializeColor3(data.MenuTextColor or State.MenuTextColor)
    local menuKey = deserializeBind(data.MenuKey, State.MenuKey)
    local aimKey = deserializeBind(data.AimKey, State.AimKey)

    local function setIf(name, value)
        local control = App.Controls[name]
        if control and control.Set then
            control:Set(value)
        end
    end

    setIf("MenuColor", menuColor)
    setIf("MenuTextColor", menuTextColor)
    setIf("MenuKey", menuKey)
    setIf("AimKey", aimKey)
    setIf("ESPEnabled", data.ESPEnabled == true)
    setIf("ESPPlayers", data.ESPPlayers == true)
    setIf("ESPNPCs", data.ESPNPCs == true)
    setIf("ESPDistance", tonumber(data.ESPDistance) or State.ESPDistance)
    setIf("ESPColor", color)
    setIf("ESPStyle", data.ESPStyle or State.ESPStyle)
    setIf("Tracers", data.Tracers == true)
    setIf("TracerOrigin", data.TracerOrigin or State.TracerOrigin)
    setIf("HealthBar", data.HealthBar == true)
    setIf("HealthBarSide", data.HealthBarSide or State.HealthBarSide)
    setIf("HealthBarThickness", tonumber(data.HealthBarThickness) or State.HealthBarThickness)
    setIf("Skeleton", data.Skeleton == true)
    setIf("SkeletonType", data.SkeletonType or State.SkeletonType)
    setIf("SkeletonThickness", tonumber(data.SkeletonThickness) or State.SkeletonThickness)
    setIf("ESPNames", data.ESPNames == true)
    setIf("ESPNameSize", tonumber(data.ESPNameSize) or State.ESPNameSize)
    setIf("ESPGlow", data.ESPGlow == true)
    setIf("CharacterPreview", data.CharacterPreview == true)
    setIf("CombatEnabled", data.CombatEnabled == true)
    setIf("ShowFOV", data.ShowFOV == true)
    setIf("FOV", tonumber(data.FOV) or State.FOV)
    setIf("Smooth", tonumber(data.Smooth) or State.Smooth)
    setIf("AimPart", data.AimPart or State.AimPart)
    setIf("WallCheck", data.WallCheck == true)
    setIf("RenderPriority", data.RenderPriority or State.RenderPriority)
    setIf("MaxRenderedTargets", tonumber(data.MaxRenderedTargets) or State.MaxRenderedTargets)
    setIf("MaxSkeletonTargets", tonumber(data.MaxSkeletonTargets) or State.MaxSkeletonTargets)
    setIf("MaxTracerTargets", tonumber(data.MaxTracerTargets) or State.MaxTracerTargets)
    setIf("MaxNameTargets", tonumber(data.MaxNameTargets) or State.MaxNameTargets)
    setIf("TargetRefreshRate", tonumber(data.TargetRefreshRate) or State.TargetRefreshRate)

    local selected = tostring(data.ConfigName or data.SelectedConfig or "default")
    State.ConfigName = selected
    State.SelectedConfig = selected
    if App.Controls.ConfigName then App.Controls.ConfigName.Set(selected) end
    if App.Controls.SelectedConfig then App.Controls.SelectedConfig.Set(selected) end

    rebuildPreview()
    refreshMenuState()
    updateFOV()
end

local function saveCurrentConfig(name)
    local clean, path = getConfigPath(name)
    State.ConfigName = clean
    State.SelectedConfig = clean
    if not canUseFiles() then
        notify("Config", "Tu ejecutor no soporta writefile/readfile.")
        return false
    end
    ensureConfigFolder()
    local payload = {
        ConfigName = clean,
        MenuColor = serializeColor3(State.MenuColor),
        MenuTextColor = serializeColor3(State.MenuTextColor),
        MenuKey = serializeBind(State.MenuKey),
        AimKey = serializeBind(State.AimKey),
        ESPEnabled = State.ESPEnabled,
        ESPPlayers = State.ESPPlayers,
        ESPNPCs = State.ESPNPCs,
        ESPDistance = State.ESPDistance,
        ESPColor = serializeColor3(State.ESPColor),
        ESPStyle = State.ESPStyle,
        Tracers = State.Tracers,
        TracerOrigin = State.TracerOrigin,
        HealthBar = State.HealthBar,
        HealthBarSide = State.HealthBarSide,
        HealthBarThickness = State.HealthBarThickness,
        Skeleton = State.Skeleton,
        SkeletonType = State.SkeletonType,
        SkeletonThickness = State.SkeletonThickness,
        ESPNames = State.ESPNames,
        ESPNameSize = State.ESPNameSize,
        ESPGlow = State.ESPGlow,
        CharacterPreview = State.CharacterPreview,
        CombatEnabled = State.CombatEnabled,
        ShowFOV = State.ShowFOV,
        FOV = State.FOV,
        Smooth = State.Smooth,
        AimPart = State.AimPart,
        WallCheck = State.WallCheck,
        RenderPriority = State.RenderPriority,
        MaxRenderedTargets = State.MaxRenderedTargets,
        MaxSkeletonTargets = State.MaxSkeletonTargets,
        MaxTracerTargets = State.MaxTracerTargets,
        MaxNameTargets = State.MaxNameTargets,
        TargetRefreshRate = State.TargetRefreshRate,
    }
    local ok, err = pcall(function()
        writefile(path, HttpService:JSONEncode(payload))
    end)
    if not ok then
        notify("Config", "No se pudo guardar: " .. tostring(err))
        return false
    end
    return clean
end

local function loadSavedConfig(name)
    local clean, path = getConfigPath(name)
    if not canUseFiles() then
        notify("Config", "Tu ejecutor no soporta readfile/listfiles.")
        return false
    end
    if not isfile(path) then
        notify("Config", "No existe esa config.")
        return false
    end
    local ok, decoded = pcall(function()
        return HttpService:JSONDecode(readfile(path))
    end)
    if not ok or type(decoded) ~= "table" then
        notify("Config", "Archivo de config inválido.")
        return false
    end
    applyLoadedState(decoded)
    return clean
end

local function getCharacter()
    return LocalPlayer.Character
end

local function getHumanoid(model)
    return model and model:FindFirstChildOfClass("Humanoid")
end

local function getRoot(model)
    if not model then return nil end
    if model:IsA("Model") then
        return model:FindFirstChild("HumanoidRootPart") or model.PrimaryPart or model:FindFirstChild("Head")
    elseif model:IsA("BasePart") then
        return model
    end
end

local function localRoot()
    return getRoot(getCharacter())
end

local function distanceTo(pos)
    local root = localRoot()
    if not root then return math.huge end
    return (root.Position - pos).Magnitude
end

local function isAliveModel(model)
    local hum = getHumanoid(model)
    return hum and hum.Health > 0
end

local function worldToViewport(pos)
    return Camera:WorldToViewportPoint(pos)
end

local function getTracerOrigin()
    local size = Camera.ViewportSize
    if State.TracerOrigin == "Top" then
        return Vector2.new(size.X/2, 0)
    elseif State.TracerOrigin == "Center" then
        return Vector2.new(size.X/2, size.Y/2)
    end
    return Vector2.new(size.X/2, size.Y)
end

local function getTargetPart(model)
    if not model then return nil end
    if State.AimPart == "Chest" then
        return model:FindFirstChild("UpperTorso") or model:FindFirstChild("Torso") or model:FindFirstChild("HumanoidRootPart") or model:FindFirstChild("Head") or getRoot(model)
    end
    return model:FindFirstChild(State.AimPart) or model:FindFirstChild("Head") or getRoot(model)
end

local function getCharacterBounds(model)
    local cf, size = model:GetBoundingBox()
    local pos = cf.Position
    local top = select(1, worldToViewport(pos + Vector3.new(0, size.Y/2, 0)))
    local bottom = select(1, worldToViewport(pos - Vector3.new(0, size.Y/2, 0)))
    return cf, size, top, bottom
end

local function createGlowText(parent, text, pos, size, textSize, font, z)
    local holder = create("Frame", {
        BackgroundTransparency = 1,
        Position = pos,
        Size = size,
        ZIndex = z or 5
    })
    holder.Parent = parent

    local layers = {
        {Vector2.new(0, 0), 0, App.Theme.Text},
        {Vector2.new(0, 0), 0.18, App.Theme.Accent},
        {Vector2.new(1, 0), 0.78, App.Theme.Accent},
        {Vector2.new(-1, 0), 0.78, App.Theme.Accent},
        {Vector2.new(0, 1), 0.78, App.Theme.Accent},
        {Vector2.new(0, -1), 0.78, App.Theme.Accent},
        {Vector2.new(2, 0), 0.9, App.Theme.Accent},
        {Vector2.new(-2, 0), 0.9, App.Theme.Accent},
        {Vector2.new(0, 2), 0.9, App.Theme.Accent},
        {Vector2.new(0, -2), 0.9, App.Theme.Accent}
    }

    for _, entry in ipairs(layers) do
        local off, trans, color = entry[1], entry[2], entry[3]
        local glow = create("TextLabel", {
            BackgroundTransparency = 1,
            Position = UDim2.new(0, off.X, 0, off.Y),
            Size = UDim2.new(1,0,1,0),
            Text = text,
            Font = font,
            TextSize = textSize,
            TextTransparency = trans,
            TextColor3 = color,
            TextXAlignment = Enum.TextXAlignment.Left,
            TextYAlignment = Enum.TextYAlignment.Center,
            ZIndex = z or 5
        })
        glow.Parent = holder
    end
    return holder
end

notify = function(title, body)
    if not App.NotificationHolder then return end
    local card = create("Frame", {
        BackgroundTransparency = 0,
        BorderSizePixel = 0,
        Size = UDim2.new(1,0,0,0),
        AutomaticSize = Enum.AutomaticSize.Y,
        ClipsDescendants = true
    })
    card.Parent = App.NotificationHolder
    registerTheme(card, "BackgroundColor3", "Panel")
    addCorner(card, 12)
    addStroke(card)

    local line = create("Frame", {BackgroundColor3 = App.Theme.Accent, BorderSizePixel = 0, Size = UDim2.new(0,3,1,0)})
    line.Parent = card
    addCorner(line, 6)

    local wrap = create("Frame", {BackgroundTransparency = 1, Position = UDim2.new(0,12,0,10), Size = UDim2.new(1,-24,0,0), AutomaticSize = Enum.AutomaticSize.Y})
    wrap.Parent = card
    local lay = create("UIListLayout", {Padding = UDim.new(0,4)})
    lay.Parent = wrap

    local t = create("TextLabel", {BackgroundTransparency=1, Size=UDim2.new(1,0,0,18), Text=title, Font=Enum.Font.GothamBold, TextSize=14, TextXAlignment=Enum.TextXAlignment.Left})
    t.Parent = wrap
    registerTheme(t, "TextColor3", "Text")

    local b = create("TextLabel", {BackgroundTransparency=1, Size=UDim2.new(1,0,0,0), AutomaticSize=Enum.AutomaticSize.Y, TextWrapped=true, Text=body, Font=Enum.Font.Gotham, TextSize=12, TextXAlignment=Enum.TextXAlignment.Left, TextYAlignment=Enum.TextYAlignment.Top})
    b.Parent = wrap
    registerTheme(b, "TextColor3", "Sub")

    task.defer(function()
        tween(card, 0.2, {Size = UDim2.new(1,0,0,wrap.AbsoluteSize.Y + 18)})
    end)
    task.delay(3.4, function()
        if card.Parent then
            tween(card, 0.18, {BackgroundTransparency = 1, Size = UDim2.new(1,0,0,0)})
            task.wait(0.22)
            if card.Parent then card:Destroy() end
        end
    end)
end

