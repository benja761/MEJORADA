local function clearPreview()
    if App.PreviewWorld then App.PreviewWorld:Destroy(); App.PreviewWorld = nil end
    if App.PreviewClone then App.PreviewClone:Destroy(); App.PreviewClone = nil end
end

local function rebuildPreview()
    clearPreview()
    if not App.Viewport or not State.CharacterPreview then
        if App.PreviewWindow then App.PreviewWindow.Visible = false end
        return
    end

    App.PreviewWindow.Visible = State.MenuVisible
    local world = Instance.new("WorldModel")
    world.Parent = App.Viewport
    App.PreviewWorld = world

    local char = getCharacter()
    if not char then return end
    local clone = char:Clone()
    for _, v in ipairs(clone:GetDescendants()) do
        if v:IsA("LocalScript") or v:IsA("Script") then
            v:Destroy()
        elseif v:IsA("BasePart") then
            v.Anchored = true
            v.CanCollide = false
        end
    end
    clone.Parent = world
    App.PreviewClone = clone

    local cam = Instance.new("Camera")
    cam.Parent = App.Viewport
    App.Viewport.CurrentCamera = cam

    local root = getRoot(clone)
    if root then
        cam.CFrame = CFrame.new(root.Position + Vector3.new(2, 1.2, 6), root.Position + Vector3.new(0, 1, 0))
    else
        cam.CFrame = CFrame.new(Vector3.new(0, 2, 6), Vector3.new(0, 1, 0))
    end

    local light = Instance.new("PointLight")
    light.Brightness = 1.5
    light.Range = 20
    light.Parent = cam
end

local function refreshMenuState()
    if not App.Root then return end
    App.Root.Visible = State.MenuVisible
    if App.PreviewWindow then
        App.PreviewWindow.Visible = State.MenuVisible and State.CharacterPreview
    end
    if App.PopupBlocker then
        App.PopupBlocker.Visible = State.MenuVisible
    end
    if State.Minimized then
        App.Root.Size = UDim2.new(0, 930, 0, 72)
        App.Sidebar.Visible = false
        App.Content.Visible = false
    else
        App.Root.Size = UDim2.new(0, 930, 0, 620)
        App.Sidebar.Visible = true
        App.Content.Visible = true
    end
    if App.Hotkey then
        App.Hotkey.Text = "Menu: " .. inputToText(State.MenuKey) .. "  |  Aim: " .. inputToText(State.AimKey) .. " [" .. (State.AimActive and "ON" or "OFF") .. "]"
    end
    updateFOV()
end

