	local state = defaultValue or values[1] or ""

	local function updatePopupPosition()
		local pos = opener.AbsolutePosition
		local size = opener.AbsoluteSize
		popup.Position = UDim2.new(0, pos.X + size.X - 116, 0, pos.Y + size.Y + 4)
	end

	local function setExpanded(v)
		expanded = v and true or false
		popup.Visible = expanded
		arrow.Text = expanded and "▴" or "▾"
		if expanded then
			updatePopupPosition()
		end
		popup.Size = UDim2.new(0, 116, 0, expanded and (math.min(#values, 6) * 24 + 12) or 0)
	end

	local function setValue(v)
		state = v
		opener.Text = tostring(v)
		arrow.Text = expanded and "▴" or "▾"
		if callback then
			callback(v)
		end
	end

	for i = 1, #values do
		local value = values[i]
		local button = create("TextButton", {
			BackgroundTransparency = 0,
			BorderSizePixel = 0,
			Size = UDim2.new(1, 0, 0, 20),
			Text = tostring(value),
			Font = Enum.Font.Gotham,
