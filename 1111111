local function createSlider(parent, text, min, max, getter, setter)
	local holder = create("Frame", {
		BackgroundColor3 = Theme.Control,
		BorderSizePixel = 0,
		Size = UDim2.new(1, 0, 0, 58),
	})
	holder.Parent = parent
	addCorner(holder, 8)
	addStroke(holder, Theme.Outline, 1)

	local label = create("TextLabel", {
		BackgroundTransparency = 1,
		Position = UDim2.new(0, 10, 0, 6),
		Size = UDim2.new(1, -70, 0, 16),
		Text = text,
		TextColor3 = Theme.Text,
		TextXAlignment = Enum.TextXAlignment.Left,
		Font = Enum.Font.GothamBold,
		TextSize = 13,
	})
	label.Parent = holder

	local valueLabel = create("TextLabel", {
		BackgroundTransparency = 1,
		AnchorPoint = Vector2.new(1, 0),
		Position = UDim2.new(1, -10, 0, 6),
		Size = UDim2.new(0, 60, 0, 16),
		Text = tostring(getter()),
		TextColor3 = Theme.Text,
		TextXAlignment = Enum.TextXAlignment.Right,
		Font = Enum.Font.Gotham,
		TextSize = 12,
	})
	valueLabel.Parent = holder

	local bar = create("Frame", {
		BackgroundColor3 = Theme.ControlDark,
		BorderSizePixel = 0,
		Position = UDim2.new(0, 10, 0, 32),
		Size = UDim2.new(1, -20, 0, 12),
	})
	bar.Parent = holder
	addCorner(bar, 8)
	local fill = create("Frame", {
		BackgroundColor3 = Theme.Accent,
		BorderSizePixel = 0,
		Size = UDim2.new(0, 0, 1, 0),
	})
	fill.Parent = bar
	addCorner(fill, 8)
	local dragging = false
	local function sync()
		local value = getter()
		local pct = (value - min) / (max - min)
		if pct < 0 then pct = 0 end
		if pct > 1 then pct = 1 end
		fill.Size = UDim2.new(pct, 0, 1, 0)
		valueLabel.Text = tostring(value)
	end
	local function setFromX(x)
		local pct = (x - bar.AbsolutePosition.X) / bar.AbsoluteSize.X
		if pct < 0 then pct = 0 end
		if pct > 1 then pct = 1 end
		local value = min + ((max - min) * pct)
		value = math.floor(value + 0.5)
		setter(value)
		sync()
	end
	connect(bar.InputBegan, function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 then
			dragging = true
			setFromX(input.Position.X)
		end
	end)
	connect(UserInputService.InputChanged, function(input)
		if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
			setFromX(input.Position.X)
		end
	end)
	connect(UserInputService.InputEnded, function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 then dragging = false end
	end)
	sync()
	registerSearch(holder, function() return text end)
	return holder, sync
end

