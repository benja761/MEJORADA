local function hookDrag()
    local dragging = false
    local startMouse, startPos

    local function begin(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = true
            startMouse = UserInputService:GetMouseLocation()
            startPos = App.Root.Position
        end
    end

    local function update()
        if dragging and startMouse and startPos then
            local mouse = UserInputService:GetMouseLocation()
            local delta = mouse - startMouse
            App.Root.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
            App.PreviewWindow.Position = UDim2.new(App.Root.Position.X.Scale, App.Root.Position.X.Offset + App.Root.AbsoluteSize.X/2 + 12, App.Root.Position.Y.Scale, App.Root.Position.Y.Offset)
        end
    end

    table.insert(App.Connections, App.DragBar.InputBegan:Connect(begin))
    table.insert(App.Connections, UserInputService.InputChanged:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseMovement then update() end
    end))
    table.insert(App.Connections, UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then dragging = false end
    end))
end

local function hookButtons()
    App.MinBtn.MouseButton1Click:Connect(function() State.Minimized = not State.Minimized; refreshMenuState() end)
    App.CloseBtn.MouseButton1Click:Connect(function()
        for _, c in ipairs(App.Connections) do safeDisconnect(c) end
        for target in pairs(App.ESP) do removeESPRecord(target) end
        clearPreview()
        App.Gui:Destroy()
    end)

    App.DiscordBtn.MouseButton1Click:Connect(function()
        local link = "https://discord.gg/kpkBywsrpD"
        local opened = false
        pcall(function()
            if GuiService and GuiService.OpenBrowserWindow then
                GuiService:OpenBrowserWindow(link)
                opened = true
            end
        end)
        if not opened then
            pcall(function()
                if GuiService and GuiService.OpenNativeOverlay then
                    GuiService:OpenNativeOverlay(link)
                    opened = true
                end
            end)
        end
        if not opened then
            notify("Discord", link)
        end
    end)

    table.insert(App.Connections, UserInputService.InputBegan:Connect(function(input, gp)
        if inputMatches(State.MenuKey, input) then
            State.MenuVisible = not State.MenuVisible
            refreshMenuState()
            return
        elseif inputMatches(State.AimKey, input) then
            if State.CombatEnabled then
                State.AimActive = not State.AimActive
                refreshMenuState()
                notify("Aim", State.AimActive and "Aim activado." or "Aim desactivado.")
            end
            return
        end

        if gp then return end

        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            if App.Popups then
                local mouse = UserInputService:GetMouseLocation()
                for _, p in ipairs(App.Popups) do
                    if p.Visible then
                        local pos, size = p.AbsolutePosition, p.AbsoluteSize
                        local inside = mouse.X >= pos.X and mouse.X <= pos.X + size.X and mouse.Y >= pos.Y and mouse.Y <= pos.Y + size.Y
                        if not inside then p.Visible = false end
                    end
                end
            end
        end
    end))
end

local function startLoop()
    local previewTick = 0
    local targetTick = 0
    local lobbyTick = 0
    table.insert(App.Connections, RunService.RenderStepped:Connect(function(dt)
        targetTick += dt
        lobbyTick += dt
        if targetTick >= State.TargetRefreshRate then
            targetTick = 0
            refreshTargetCache()
        end
        updateESP()
        updateAim()
        updateFOV()
        previewTick += dt
        if previewTick >= 1.35 and State.CharacterPreview then
            previewTick = 0
            rebuildPreview()
        end
        if lobbyTick >= 2.5 then
            lobbyTick = 0
            if App.Pages and App.Pages["Perf"] and App.Pages["Perf"].Visible then
                refreshLobbyCards()
            end
        end
    end))
    table.insert(App.Connections, LocalPlayer.CharacterAdded:Connect(function()
        task.wait(0.8)
        rebuildPreview()
    end))
    table.insert(App.Connections, Players.PlayerAdded:Connect(function()
        task.wait(0.25)
        if App.Pages and App.Pages["Perf"] and App.Pages["Perf"].Visible then refreshLobbyCards() end
    end))
    table.insert(App.Connections, Players.PlayerRemoving:Connect(function()
        task.wait()
        if App.Pages and App.Pages["Perf"] and App.Pages["Perf"].Visible then refreshLobbyCards() end
    end))
end

buildUI()
buildPages()
if App.Controls.SelectedConfig and App.Controls.SelectedConfig.SetOptions then
    App.Controls.SelectedConfig.SetOptions(listConfigNames(), State.SelectedConfig)
end
refreshLobbyCards()
switchTab("Main")
hookDrag()
hookButtons()
startLoop()

App.Root.Visible = false
App.PreviewWindow.Visible = false
updateFOV()

notify("Loaded", "Intro will finish in 5 seconds.")

task.delay(5, function()
    if App.Intro and App.Intro.Parent then
        tween(App.Intro, 0.35, {BackgroundTransparency = 1})
        for _, desc in ipairs(App.Intro:GetDescendants()) do
            if desc:IsA("TextLabel") then
                tween(desc, 0.35, {TextTransparency = 1})
            end
        end
        task.wait(0.4)
        if App.Intro and App.Intro.Parent then App.Intro:Destroy() end
    end
    State.MenuVisible = true
    refreshTargetCache()
    refreshLobbyCards()
    refreshMenuState()
    App.Root.Visible = true
    notify("Nexhidera", "Menu loaded correctly.")
end)
