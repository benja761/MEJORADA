	end

	connect(btn.MouseButton1Click, function()
		setValue(not state)
	end)

	setValue(state)
	return { Set = setValue, Get = function() return state end, Holder = holder }
end

local function makeSlider(parent, text, min, max, defaultValue, callback)
	local value = defaultValue or min
	local holder = create("Frame", {
		Size = UDim2.new(1, 0, 0, 58),
		BackgroundColor3 = Theme.Control,
		BorderSizePixel = 0,
		Parent = parent,
	})
	addCorner(holder, 9)
	addStroke(holder, Theme.Outline, 1)
	registerEntry(holder, { text })

	local label = create("TextLabel", {
		BackgroundTransparency = 1,
		Position = UDim2.new(0, 10, 0, 6),
		Size = UDim2.new(1, -80, 0, 16),
		Text = text,
		TextColor3 = Theme.Text,
		Font = Enum.Font.GothamBold,
		TextSize = 13,
		TextXAlignment = Enum.TextXAlignment.Left,
		Parent = holder,
	})

	local valueLabel = create("TextLabel", {
		BackgroundTransparency = 1,
		AnchorPoint = Vector2.new(1, 0),
		Position = UDim2.new(1, -10, 0, 6),
		Size = UDim2.new(0, 70, 0, 16),
		Text = tostring(value),
		TextColor3 = Theme.Sub,
		Font = Enum.Font.GothamBold,
		TextSize = 12,
		TextXAlignment = Enum.TextXAlignment.Right,
		Parent = holder,
	})

	local bar = create("Frame", {
		Position = UDim2.new(0, 10, 0, 34),
		Size = UDim2.new(1, -20, 0, 10),
		BackgroundColor3 = Theme.ControlDark,
		BorderSizePixel = 0,
		Parent = holder,
	})
	addCorner(bar, 8)

	local fill = create("Frame", {
		Size = UDim2.new(0, 0, 1, 0),
		BackgroundColor3 = Theme.Accent,
		BorderSizePixel = 0,
		Parent = bar,
	})
	addCorner(fill, 8)

	local dragging = false

	local function setValue(v)
		v = math.clamp(v, min, max)
		value = math.floor(v + 0.5)
		valueLabel.Text = tostring(value)
		fill.Size = UDim2.new((value - min) / (max - min), 0, 1, 0)
		if callback then callback(value) end
	end

	local function updateFromX(x)
		local pct = math.clamp((x - bar.AbsolutePosition.X) / bar.AbsoluteSize.X, 0, 1)
		setValue(min + (max - min) * pct)
	end

	connect(bar.InputBegan, function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 then
			dragging = true
			updateFromX(input.Position.X)
		end
	end)
	connect(UserInputService.InputChanged, function(input)
		if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
			updateFromX(input.Position.X)
		end
	end)
	connect(UserInputService.InputEnded, function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 then
			dragging = false
		end
	end)

	setValue(value)
	return { Set = setValue, Get = function() return value end, Holder = holder }
end

