	task.defer(function()
		finalHeight = container.AbsoluteSize.Y + 16
		tween(note, TweenInfo.new(0.2, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {Size = UDim2.new(1, 0, 0, finalHeight)})
	end)
