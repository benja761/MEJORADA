function SectionTable:Dropdown(Name, Options, Default, Callback)

	local DropFrame = Instance.new("Frame")
	DropFrame.Size = UDim2.new(1,-10,0,35)
	DropFrame.BackgroundTransparency = 1
	DropFrame.Parent = self.Container

	local Title = Instance.new("TextLabel")
	Title.Size = UDim2.new(1,-10,0,16)
	Title.Position = UDim2.new(0,10,0,0)
	Title.BackgroundTransparency = 1
	Title.Text = Name
	Title.Font = Enum.Font.Gotham
	Title.TextSize = 14
	Title.TextColor3 = Theme.Text
	Title.TextXAlignment = Enum.TextXAlignment.Left
	Title.Parent = DropFrame

	local Button = Instance.new("TextButton")
	Button.Size = UDim2.new(1,-20,0,20)
	Button.Position = UDim2.new(0,10,0,16)
	Button.BackgroundColor3 = Color3.fromRGB(40,40,40)
	Button.Text = Default or "Select"
	Button.Font = Enum.Font.Gotham
	Button.TextSize = 13
	Button.TextColor3 = Theme.Text
	Button.Parent = DropFrame

	local Corner = Instance.new("UICorner")
	Corner.Parent = Button

	local ListFrame = Instance.new("Frame")
	ListFrame.Size = UDim2.new(1,-20,0,0)
	ListFrame.Position = UDim2.new(0,10,0,38)
	ListFrame.BackgroundColor3 = Color3.fromRGB(35,35,35)
	ListFrame.ClipsDescendants = true
	ListFrame.Visible = false
	ListFrame.Parent = DropFrame

	local ListCorner = Instance.new("UICorner")
	ListCorner.Parent = ListFrame

	local Layout = Instance.new("UIListLayout")
	Layout.Parent = ListFrame
	Layout.Padding = UDim.new(0,3)

	local Open = false

	local function ToggleDropdown()

		Open = not Open

		ListFrame.Visible = true

		if Open then

			local Size = #Options * 22

			TweenService:Create(ListFrame,TweenInfo.new(.25),{
				Size = UDim2.new(1,-20,0,Size)
			}):Play()

		else

			TweenService:Create(ListFrame,TweenInfo.new(.25),{
				Size = UDim2.new(1,-20,0,0)
			}):Play()

			task.wait(.25)

			ListFrame.Visible = false

		end

	end

	Button.MouseButton1Click:Connect(ToggleDropdown)

	for i,v in pairs(Options) do

		local Option = Instance.new("TextButton")
		Option.Size = UDim2.new(1,0,0,20)
		Option.BackgroundTransparency = 1
		Option.Text = v
		Option.Font = Enum.Font.Gotham
		Option.TextSize = 13
		Option.TextColor3 = Theme.Text
		Option.Parent = ListFrame

		Option.MouseButton1Click:Connect(function()

			Button.Text = v

			if Callback then
				Callback(v)
			end

			ToggleDropdown()

		end)

	end

end
